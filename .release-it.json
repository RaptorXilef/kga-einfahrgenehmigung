{
  "plugins": {},
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "commit": true,
    "tag": true,
    "push": true,
    "changelog": "npx conventional-changelog-cli --config changelog-config.cjs -r 1"
  },
  "hooks": {
    "before:release": "npx conventional-changelog-cli --config changelog-config.cjs -i CHANGELOG.md -s -r 0"
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  }
}
