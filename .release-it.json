{
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "CHANGELOG.md",
      "configuration": "changelog-config.cjs",
      "ignoreRecommendedBump": true,
      "strict": false
    }
  },
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "commit": true,
    "tag": true,
    "push": true,
    "changelog": false
  },
  "github": { "release": false },
  "npm": { "publish": false }
}
