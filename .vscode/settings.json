{
    // =========================================================================
    // EDITOR & FORMATTING CORE
    // =========================================================================
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "biomejs.biome",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [120],
    "editor.bracketPairColorization.enabled": true,
    "editor.linkedEditing": true,
    "files.eol": "\n", // Unix-Zeilenenden für Git-Konsistenz
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000, // Wenn CPU Last zu hoch auf 3000 oder 5000 erhöhen

    "gremlins.showInProblemPane": true,

    // =========================================================================
    // SPRACH-SPEZIFISCHE EINSTELLUNGEN
    // =========================================================================

    // Verhindert, dass VS Code Biome nach Teilbereichs-Formatierung fragt
    "editor.formatOnType": false,
    "editor.formatOnPaste": false,

    // --- PHP & INTELEPHENSE ---
    "[php]": {
        //"editor.defaultFormatter": "bmewburn.vscode-intelephense-client", // Intelephense als Basis
        "editor.defaultFormatter": "muuvmuuv.vscode-just-php-cs-fixer",
        "editor.wordWrap": "off",
        "editor.renderWhitespace": "boundary"
    },
    "[phtml]": {
        //"editor.defaultFormatter": "bmewburn.vscode-intelephense-client", // Intelephense als Basis
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
        "editor.wordWrap": "off",
        "editor.renderWhitespace": "boundary",
        "editor.formatOnSave": true
    },
    "intelephense.format.enable": false, // CLI-Tools (PHP-CS-Fixer) haben Vorrang!
    "php.suggest.basic": false,
    "php-docblocker.gap": true,

    // --- BIOME (JS, JSON, CSS/SCSS) ---
    "[javascript]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        // WICHTIG: Mode auf "file" setzen, nicht "modifications"
        "editor.formatOnSaveMode": "file"
    },
    "[json]": { "editor.defaultFormatter": "biomejs.biome" },
    "[jsonc]": { "editor.defaultFormatter": "biomejs.biome" },
    "[scss]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": { "source.fixAll.stylelint": "explicit" }
    },

    // --- HTML & MARKUPLINT ---
    "[html]": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": { "source.fixAll.markuplint": "explicit" }
    },

    // --- MARKDOWN & REWRAP ---
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
        "editor.wordWrap": "on"
    },
    "rewrap.wrappingColumn": 120,
    "rewrap.wholeComment": true,

    // =========================================================================
    // EXPLORER, SEARCH & WATCHER (Performance & Ordnung)
    // =========================================================================
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.DS_Store": true,
        "**/node_modules": false, // Wir wollen sie sehen, aber...
        "**/vendor": false, // ...unten in der Suche ausschließen
        "**/.build": true,
        "**/.cache": true,
        "**/.debug": true,
        "**/*.map": true,
        ".phpcs.cache": true,
        ".phpstan.cache": true,
        ".phpunit.cache": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/vendor": true,
        "**/.build": true,
        "**/.cache": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/node_modules/**": true,
        "**/vendor/**": true,
        "**/.debug/**": true
    },
    "intelephense.diagnostics.undefinedTypes": true,
    "intelephense.diagnostics.exclude": ["**/.cache/**", "**/temp/**"],
    "intelephense.files.exclude": [
        "**/.cache/**",
        "**/.build/**",
        "**/.php-cs-fixer.dist.php",
        "**/.git/**",
        "**/.svn/**",
        "**/.hg/**",
        "**/CVS/**",
        "**/.DS_Store/**",
        "**/node_modules/**",
        "**/bower_components/**"
    ],
    // Das hier hilft, wenn Intelephense hängen bleibt
    "intelephense.completion.fullyQualifyImportNames": true,

    "draw.folder.structure.exclude": [
        "**/node_modules",
        "**/.git",
        "**/dist",
        "**/.next",
        "**/out",
        "**/.build",
        "**/.cache",
        "**/.debug",
        "**/.github",
        "**/.husky",
        "**/.vscode",
        "**/docs",
        "**/scripts",
        "**/tools",
        "**/vendor"
    ],

    // =========================================================================
    // TOOLS & WORKFLOW (Meine persönlichen Favoriten)
    // =========================================================================

    // --- DIFF EDITOR ---
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.experimental.showMoves": true,
    "diffEditor.codeLens": true,
    "diffEditor.maxComputationTime": 30000,

    // --- TODO TREE ---
    /*"better-todo-tree.general.tags": [
        "BUG",
        "HACK",
        "FIXME",
        "TODO",
        "XXX",
        "[ ]",
        "[x]",
        "VOR_RELEASE"
    ],
    "better-todo-tree.highlights.useColourScheme": true,
    "better-todo-tree.highlights.backgroundColourScheme": [
        "red",
        "orange",
        "yellow",
        "green",
        "blue",
        "indigo",
        "violet",
        "purple"
    ],*/
    //"better-todo-tree.filtering.excludeGlobs": ["**/node_modules/**", "**/vendor/**", "**/*.pdf"],

    // --- SPELL CHECK ---
    "cSpell.language": "en,de",
    "cSpell.diagnosticLevel": "Hint",

    // --- TERMINAL ---
    "terminal.integrated.defaultProfile.windows": "Git Bash",

    // --- THEME ---
    "errorLens.onInlayHints": true,

    // --- Vira Theme ---
    "files.insertFinalNewline": true,
    "workbench.iconTheme": "vira-icons-carbon",
    "workbench.productIconTheme": "viraUIIcons",
    "workbench.colorTheme": "Vira Carbon High Contrast",
    "workbench.colorCustomizations": {
        "[Vira*]": {
            "statusBar.debuggingBackground": "#FFFFFF33",
            "statusBar.debuggingForeground": "#FFFFFF",
            "toolbar.activeBackground": "#FFFFFF26",
            "button.background": "#FFFFFF",
            "button.hoverBackground": "#FFFFFFcc",
            "extensionButton.separator": "#FFFFFF33",
            "extensionButton.background": "#FFFFFF14",
            "extensionButton.foreground": "#FFFFFF",
            "extensionButton.hoverBackground": "#FFFFFF33",
            "extensionButton.prominentForeground": "#FFFFFF",
            "extensionButton.prominentBackground": "#FFFFFF14",
            "extensionButton.prominentHoverBackground": "#FFFFFF33",
            "activityBarBadge.background": "#FFFFFF",
            "activityBar.activeBorder": "#FFFFFF",
            "activityBarTop.activeBorder": "#FFFFFF",
            "list.inactiveSelectionIconForeground": "#FFFFFF",
            "list.activeSelectionForeground": "#FFFFFF",
            "list.inactiveSelectionForeground": "#FFFFFF",
            "list.highlightForeground": "#FFFFFF",
            "sash.hoverBorder": "#FFFFFF80",
            "list.activeSelectionIconForeground": "#FFFFFF",
            "scrollbarSlider.activeBackground": "#FFFFFF80",
            "editorSuggestWidget.highlightForeground": "#FFFFFF",
            "textLink.foreground": "#FFFFFF",
            "progressBar.background": "#FFFFFF",
            "pickerGroup.foreground": "#FFFFFF",
            "tab.activeBorder": "#FFFFFF",
            "tab.activeBorderTop": "#FFFFFF00",
            "tab.unfocusedActiveBorder": "#FFFFFF",
            "tab.unfocusedActiveBorderTop": "#FFFFFF00",
            "tab.activeModifiedBorder": "#FFFFFF00",
            "notificationLink.foreground": "#FFFFFF",
            "editorWidget.resizeBorder": "#FFFFFF",
            "editorWidget.border": "#FFFFFF",
            "settings.modifiedItemIndicator": "#FFFFFF",
            "panelTitle.activeBorder": "#FFFFFF",
            "breadcrumb.activeSelectionForeground": "#FFFFFF",
            "menu.selectionForeground": "#FFFFFF",
            "menubar.selectionForeground": "#FFFFFF",
            "editor.findMatchBorder": "#FFFFFF",
            "selection.background": "#FFFFFF40",
            "statusBarItem.remoteBackground": "#FFFFFF14",
            "statusBarItem.remoteHoverBackground": "#FFFFFF",
            "statusBarItem.remoteForeground": "#FFFFFF",
            "notebook.inactiveFocusedCellBorder": "#FFFFFF80",
            "chat.slashCommandForeground": "#FFFFFF",
            "chat.avatarForeground": "#FFFFFF",
            "activityBarBadge.foreground": "#000000",
            "button.foreground": "#000000",
            "statusBarItem.remoteHoverForeground": "#000000"
        }
    },
    "viraTheme.accent": "White"

    // -- HINWEISE ---
    // vscode://settings/php-cs-fixer.allow-risky muss auf true gesetzt werden! Also Haken rein!
}
