 * @var string       $erstellt
 * @var string       $vereinsName
 * @var array|string $opening
 * @var array        $settings
 * @var string|null  $holidayNotice
 */
$isPermanent = \str_contains(\strtolower($template_key), 'perm');
$headerColor = $isPermanent ? '#3498db' : $jahresFarbe;
$title       = $isPermanent ? 'DAUER&shy;EINFAHRT&shy;GENEHMIGUNG' : 'AUSNAHME&shy;GENEHMIGUNG';

$displayVon = ($von_formatted ?? '') ?: ($von instanceof \DateTimeInterface ? $von->format('d.m.Y') : $von);
$displayBis = ($bis_formatted ?? '') ?: ($bis instanceof \DateTimeInterface ? $bis->format('d.m.Y') : $bis);

$dtVon = \DateTimeImmutable::createFromFormat('d.m.Y', $von_formatted);
$dtBis = \DateTimeImmutable::createFromFormat('d.m.Y', $bis_formatted);

$activeQuarters = [];
if ($dtVon && $dtBis) {
    $qStart         = (int) \ceil((int) $dtVon->format('n') / 3);
    $qEnd           = (int) \ceil((int) $dtBis->format('n') / 3);
    $activeQuarters = \range($qStart, $qEnd);
}

$baseUrl = '';
if (isset($settings['base_url']) && \is_string($settings['base_url'])) {
    $baseUrl = $settings['base_url'];
} elseif (isset($_SERVER['HTTP_HOST'])) {
    $protocol = (isset($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https://' : 'http://';
    $baseUrl  = $protocol . $_SERVER['HTTP_HOST'] . '/';
}

$openingText = 'Siehe Aushang';
if (isset($opening) && $opening !== '') {
    // Der HolidayService liefert jetzt bereits perfekt formatiertes HTML!
    $openingText = $opening;
}
