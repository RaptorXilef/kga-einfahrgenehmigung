/**
 * Page: A4 Ausnahmegenehmigung (Dokument)
 *
 * Diese Version ist optimiert für den Versand via Mail-Queue (flache Datenstrukturen).
 *
 * @var string $templateKey
 * @var string $jahresFarbe
 * @var string $vereinsName
 * @var string $fullIdentifier
 * @var string $checkUrl
 * @var string $von_formatted
 * @var string $bis_formatted
 * @var string $kennzeichen
 * @var string $firma
 * @var string $parzelle
 * @var string $zweck
 * @var string $terminkalenderUrl
 * @var string $erstellt
 * @var string $opening
 */

// 1. Bestimmung des Typs und der Farben
// Da wir kein $config Objekt mehr haben, prüfen wir den Key einfach auf "perm"
$isPermanent = \str_contains(\strtolower($templateKey), 'perm');

// Die permanent_color war in der config meist #3498db (Blau)
$headerColor = $isPermanent ? '#3498db' : $jahresFarbe;
$title       = $isPermanent ? 'DAUEREINFAHRGENEHMIGUNG' : 'AUSNAHMEGENEHMIGUNG';

// Falls die Variablen als Objekte kommen (Druckvorschau), formatieren wir sie.
// Falls sie als Strings kommen (E-Mail Queue), nutzen wir sie direkt.
$displayVon = ($von_formatted ?? '') ?: ($von instanceof \DateTimeInterface ? $von->format('d.m.Y') : $von);
$displayBis = ($bis_formatted ?? '') ?: ($bis instanceof \DateTimeInterface ? $bis->format('d.m.Y') : $bis);

// Quartals-Logik auf die neuen Variablen umstellen
$dtVon = \DateTimeImmutable::createFromFormat('d.m.Y', $von_formatted);
$dtBis = \DateTimeImmutable::createFromFormat('d.m.Y', $bis_formatted);

$activeQuarters = [];
if ($dtVon && $dtBis) {
    $qStart         = (int) \ceil((int) $dtVon->format('n') / 3);
    $qEnd           = (int) \ceil((int) $dtBis->format('n') / 3);
    $activeQuarters = \range($qStart, $qEnd);
}
?>

