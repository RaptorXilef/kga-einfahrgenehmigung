/**
 * Template: A4 Printable Permit Document (A4 Ausnahmegenehmigung)
 *
 * Das offizielle Genehmigungsdokument als HTML/PDF.
 * Diese Version ist optimiert für den Versand via Mail-Queue und die Druckansicht.
 *
 * @var string       $templateKey
 * @var string       $jahresFarbe
 * @var string       $von_formatted
 * @var string       $bis_formatted
 * @var string       $von
 * @var string       $bis
 * @var string       $fullIdentifier
 * @var string       $checkUrl
 * @var string       $kennzeichen
 * @var string       $firma
 * @var string       $parzelle
 * @var string       $zweck
 * @var string       $terminkalenderUrl
 * @var string       $erstellt
 * @var string       $vereinsName
 * @var array|string $opening
 * @var array        $settings
 */

// 1. Bestimmung des Typs und der Farben
// Da wir kein $config Objekt mehr haben, prüfen wir den Key einfach auf "perm"
$isPermanent = \str_contains(\strtolower($templateKey), 'perm');

// Die permanent_color war in der config meist #3498db (Blau)
$headerColor = $isPermanent ? '#3498db' : $jahresFarbe;
$title       = $isPermanent ? 'DAUEREINFAHRGENEHMIGUNG' : 'AUSNAHMEGENEHMIGUNG';

// Falls die Variablen als Objekte kommen (Druckvorschau), formatieren wir sie.
// Falls sie als Strings kommen (E-Mail Queue), nutzen wir sie direkt.
$displayVon = ($von_formatted ?? '') ?: ($von instanceof \DateTimeInterface ? $von->format('d.m.Y') : $von);
$displayBis = ($bis_formatted ?? '') ?: ($bis instanceof \DateTimeInterface ? $bis->format('d.m.Y') : $bis);

// Quartals-Logik auf die neuen Variablen umstellen
$dtVon = \DateTimeImmutable::createFromFormat('d.m.Y', $von_formatted);
$dtBis = \DateTimeImmutable::createFromFormat('d.m.Y', $bis_formatted);

$activeQuarters = [];
if ($dtVon && $dtBis) {
    $qStart         = (int) \ceil((int) $dtVon->format('n') / 3);
    $qEnd           = (int) \ceil((int) $dtBis->format('n') / 3);
    $activeQuarters = \range($qStart, $qEnd);
}

// Sichere Ermittlung der Basis-URL ohne Array-Konvertierungsfehler
$baseUrl = '';
if (isset($settings['base_url']) && \is_string($settings['base_url'])) {
    $baseUrl = $settings['base_url'];
} elseif (isset($_SERVER['HTTP_HOST'])) {
    $protocol = (isset($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https://' : 'http://';
    $baseUrl  = $protocol . $_SERVER['HTTP_HOST'] . '/';
}

// --- NEU: Robuste Formatierung der Öffnungszeiten direkt im Template ---
$openingText = 'Siehe Aushang';
if (isset($opening) && \is_array($opening) && ! empty($opening)) {
    $daysMap = [
        'mon' => 'Mo',
        'tue' => 'Di',
        'wed' => 'Mi',
        'thu' => 'Do',
        'fri' => 'Fr',
        'sat' => 'Sa',
        'sun' => 'So',
    ];
    $formattedDays = [];
    foreach ($daysMap as $k => $label) {
        if (! empty($opening[$k])) {
            $times           = \array_map(fn ($s) => $s[0] . ' - ' . $s[1], $opening[$k]);
            $formattedDays[] = "<strong>{$label}:</strong> " . \implode(', ', $times);
        }
    }
    $openingText = \implode(' &nbsp;|&nbsp; ', $formattedDays);
} elseif (isset($opening) && \is_string($opening) && $opening !== '') {
    $openingText = $opening;
}
