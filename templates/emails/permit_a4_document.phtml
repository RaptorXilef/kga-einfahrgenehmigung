/**
 * Template: A4 Printable Permit Document (A4 Ausnahmegenehmigung)
 *
 * Das offizielle Genehmigungsdokument als HTML/PDF.
 * Diese Version ist optimiert für den Versand via Mail-Queue und die Druckansicht.
 *
 * Path: templates/emails/permit_a4_document.phtml
 *
 * SPDX-License-Identifier: LicenseRef-Proprietary
 * Copyright (c) 2026 Felix Maywald alias RaptorXilef. All rights reserved.
 * Usage without explicit permission is strictly prohibited.
 * See LICENSE.md for full license details.
 *
 * @var string       $template_key
 * @var string       $jahresFarbe
 * @var string       $von_formatted
 * @var string       $bis_formatted
 * @var string       $von
 * @var string       $bis
 * @var string       $fullIdentifier
 * @var string       $checkUrl
 * @var string       $kennzeichen
 * @var string       $firma
 * @var string       $parzelle
 * @var string       $zweck
 * @var string       $terminkalenderUrl
 * @var string       $erstellt
 * @var string       $vereinsName
 * @var array|string $opening
 * @var array        $settings
 * @var string|null  $holidayNotice
 */
$isPermanent = \str_contains(\strtolower($template_key), 'perm');
$headerColor = $isPermanent ? '#3498db' : $jahresFarbe;
$title       = $isPermanent ? 'DAUER&shy;EINFAHRT&shy;GENEHMIGUNG' : 'AUSNAHME&shy;GENEHMIGUNG';

$displayVon = ($von_formatted ?? '') ?: ($von instanceof \DateTimeInterface ? $von->format('d.m.Y') : $von);
$displayBis = ($bis_formatted ?? '') ?: ($bis instanceof \DateTimeInterface ? $bis->format('d.m.Y') : $bis);

$dtVon = \DateTimeImmutable::createFromFormat('d.m.Y', $von_formatted);
$dtBis = \DateTimeImmutable::createFromFormat('d.m.Y', $bis_formatted);

$activeQuarters = [];
if ($dtVon && $dtBis) {
    $qStart         = (int) \ceil((int) $dtVon->format('n') / 3);
    $qEnd           = (int) \ceil((int) $dtBis->format('n') / 3);
    $activeQuarters = \range($qStart, $qEnd);
}

$baseUrl = '';
if (! empty($settings['base_url'])) {
    $baseUrl = \rtrim((string) $settings['base_url'], '/') . '/';
} else {
    // Wenn keine Base-URL existiert, brechen wir die Erstellung ab
    throw new \RuntimeException('Sicherheits-Abbruch: "base_url" fehlt für die PDF/E-Mail-Generierung.');
}

$openingText = 'Siehe Aushang';
if (isset($opening_html) && \is_string($opening_html) && $opening_html !== '') {
    $openingText = $opening_html;
} elseif (isset($opening) && \is_string($opening) && $opening !== '') {
    // Fallback, falls gerade noch eine alte Mail in der Warteschlange verarbeitet wird
    $openingText = $opening;
}
