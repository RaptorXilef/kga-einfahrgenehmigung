<?php

/**
 * Page: Public View (Check)
 *
 * Öffentliche Kontrollansicht (z.B. bei QR-Code-Scan durch externe Personen oder Wachpersonal).
 * Zeigt reduzierte, datenschutzkonforme Status-Informationen einer Genehmigung an.
 *
 * Path: templates/pages/check/public.phtml
 *
 * @var string                            $appRoot         Absoluter Pfad zum Installationsverzeichnis.
 * @var \App\Core\Entity\Permit           $permit          Die gefundene Genehmigungs-Entität.
 * @var bool                              $isDateValid     Ob das Ticket im Datumsbereich liegt.
 * @var bool                              $isTimeAllowed   Ob laut HolidayService jetzt die Einfahrt erlaubt ist.
 * @var array                             $settings        Globale UI- und App-Einstellungen.
 * @var \App\Infrastructure\Config\Config $config          Anwendungs-Konfiguration.
 * @var string                            $allowedToday    Textuelle Info zum nächsten erlaubten Einfahrts-Slot.
 * @var string                            $opening         Textuelle Zusammenfassung der Öffnungszeiten.
 * @var string|null                       $holidayNotice   Warnung bei Feiertagen im gewählten Zeitraum.
 */

// 1. Logo-Logik
$logoFile = null;
foreach (['webp', 'png', 'jpg', 'jpeg'] as $ext) {
    // Prüfe absolut auf dem Server
    $serverPath = \rtrim($appRoot, '/\\') . '/public/assets/img/logo/kga.' . $ext;
    if (\file_exists($serverPath)) {
        $logoFile = 'assets/img/logo/kga.' . $ext;

        break;
    }
}

// 2. Status-Farbe bestimmen
$pageStateClass = 'state-bg-error'; // Default: Ungültig
if ($permit) {
    if ($permit->status->is_suspended) {
        $pageStateClass = 'state-bg-error';
    } elseif ($isDateValid && $isTimeAllowed) {
        $pageStateClass = 'state-bg-valid';
    } elseif ($isDateValid && ! $isTimeAllowed) {
        $pageStateClass = 'state-bg-rest';
    }
}

?>
<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">
    <title>Status-Check - <?php echo \htmlspecialchars($settings['vereins_name']); ?></title>
    <?php include_once $appRoot . '/templates/components/_favicon.phtml'; ?>
    <link rel="stylesheet"
          href="<?php echo $settings['base_url']; ?>assets/css/main.min.css">
    <?php include $appRoot . '/templates/components/_base_styles.phtml'; ?>
</head>

<!-- Dynamische Klasse am Body -->

<body class="l-public-body <?php echo $pageStateClass; ?>">
    <?php include $appRoot . '/templates/components/_test_mode_indicator.phtml'; ?>
    <?php include $appRoot . '/templates/components/_public_header_nav.phtml'; ?>

    <main class="c-tab-content-container u-padding-y-l">
        <div class="c-card u-margin-auto"
             style="max-width: 550px;">

            <header class="c-card__header u-text-center u-padding-around-l">
                <?php if ($logoFile) { ?>
                    <img src="<?php echo $settings['base_url'] . $logoFile; ?>"
                         alt="Logo"
                         style="max-height: 120px; object-fit: contain;">
                <?php } ?>
                <p class="u-text-muted u-text-small u-margin-none"><?php echo \htmlspecialchars($settings['vereins_name']); ?></p>
            </header>

            <div class="c-card__body u-padding-around-l u-text-center">

                <?php if ($permit) { ?>
                    <?php if ($permit->status->is_suspended) { ?>
                        <div style="color: var(--danger-color);">
                            <span style="font-size: 5rem;">
                                <img src="<?php echo $settings['base_url']; ?>assets/img/icons/status-denied.webp" class="c-icon" alt="">
                            </span>
                            <h2 style="color: var(--danger-color); margin-top: 15px;">ZUTRITT VERWEIGERT</h2>
                            <p class="u-font-bold">Diese Genehmigung wurde gesperrt/widerrufen.</p>

                            <?php if (! empty($permit->status->suspension_reason)) { ?>
                                <div
                                     style="background: #fff1f2; border: 1px solid #fecaca; padding: 15px; border-radius: 12px; margin-top: 15px; text-align: center;">
                                    <strong
                                            style="font-size: 0.85rem; text-transform: uppercase; color: #991b1b; letter-spacing: 0.5px;">
                                        Grund der Sperrung:
                                    </strong>
                                    <br>
                                    <span style="color: #7f1d1d; font-size: 1.05rem; display: block; margin-top: 5px;">
                                        <?php echo \htmlspecialchars($permit->status->suspension_reason); ?>
                                    </span>
                                </div>
                            <?php } ?>
                        </div>
                    <?php } elseif ($isDateValid && $isTimeAllowed) { ?>
                        <div style="color: var(--success-color);">
                            <span style="font-size: 5rem;"><img src="<?php echo $settings['base_url']; ?>assets/img/icons/status-success.webp" class="c-icon" alt=""></span>
                            <h2 style="color: var(--success-color); margin-top: 15px;">GÜLTIG</h2>
                            <?php include '_details.phtml'; ?>
                        </div>
                    <?php } elseif ($isDateValid && ! $isTimeAllowed) { ?>
                        <div style="color: #f59e0b;">
                            <span style="font-size: 5rem;">⏳</span>
                            <h2 style="color: #f59e0b; margin-top: 15px;">AKTUELL RUHEZEIT<br>Keine Einfahrt erlaubt!
                            </h2>

                            <?php if (\str_contains($allowedToday, 'Gültigkeit')) { ?>
                                <!-- Sonderfall: Genehmigung läuft während der Ruhezeit ab -->
                                <p><strong><?php echo $allowedToday; ?></strong></p>
                            <?php } else { ?>
                                <!-- Normalfall: Nächste Zeit anzeigen -->
                                <p>Nächste Einfahrt möglich:<br><strong><?php echo $allowedToday; ?></strong></p>
                            <?php } ?>

                            <?php include '_details.phtml'; ?>
                        </div>
                    <?php } else { ?>
                        <div style="color: var(--text-muted);">
                            <span style="font-size: 5rem;"><img src="<?php echo $settings['base_url']; ?>assets/img/icons/status-invalid.webp" class="c-icon" alt=""></span>
                            <h2 style="margin-top: 15px;">UNGÜLTIG</h2>
                            <p>Zahlung offen, Zeitraum abgelaufen oder noch nicht erreicht.</p>
                        </div>
                    <?php } ?>
                <?php } ?>
            </div>

            <?php if ($permit) { ?>
                <footer class="u-padding-around-m u-text-center u-border-top"
                        style="background: #fcfdfe;">
                    <p class="u-text-muted u-margin-bottom-s">SmartCode: <strong><?php echo $permit->code; ?></strong></p>
                    <a href="admin.php?code=<?php echo $permit->code; ?>" class="u-text-link u-text-small">Login für Details</a>
                </footer>
            <?php } ?>
        </div>
    </main>
    <?php include $appRoot . '/templates/components/_footer.phtml'; ?>
</body>

</html>
