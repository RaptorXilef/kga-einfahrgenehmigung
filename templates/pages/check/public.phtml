// 1. Logo-Logik
$logoFile = null;
foreach (['png', 'webp', 'jpg', 'jpeg'] as $ext) {
    if (\file_exists("assets/img/kga_logo.$ext")) {
        $logoFile = "assets/img/kga_logo.$ext";

        break;
    }
}

// 2. Status-Farbe bestimmen
$pageStateClass = 'state-bg-error'; // Default: Ungültig
if ($permit) {
    if ($permit->status->isSuspended) {
        $pageStateClass = 'state-bg-error';
    } elseif ($isDateValid && $isTimeAllowed) {
        $pageStateClass = 'state-bg-valid';
    } elseif ($isDateValid && ! $isTimeAllowed) {
        $pageStateClass = 'state-bg-rest';
    }
} elseif ($tempData) {
    $pageStateClass = 'state-bg-valid'; // Während der Zahlung dezent neutral/grün
}

?>
<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Status-Check - <?php echo \htmlspecialchars($settings['vereins_name']); ?></title>
    <link rel="stylesheet" href="<?php echo $settings['base_url']; ?>assets/css/main.min.css">
    <?php include $appRoot . '/templates/components/_base_styles.phtml'; ?>

