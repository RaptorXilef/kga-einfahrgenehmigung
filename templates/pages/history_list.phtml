                                    $countdownText = ($remaining === 0) ? 'Läuft heute ab' : "Noch $remaining Tage";
                                }

                                // 2. Finanz-Berechnungen
                                $isPaid      = \strtolower($permit->status->current) === 'bezahlt';
                                $statusText  = \strtoupper($permit->status->current);
                                $statusClass = 'warning'; // default Orange

                                if ($isPaid) {
                                    $statusClass = 'success';
                                } else {
                                    // Überfälligkeit checken via Service
                                    $overdueLevel = $permitService->getOverdueLevel($permit);
                                    if ($overdueLevel === 2) {
                                        $statusClass = 'danger'; // Rot
                                        $statusText  = 'ZAHLUNG ÜBERFÄLLIG';
                                    } elseif ($overdueLevel === 1) {
                                        $statusText = 'MAHNFRIST';
                                    } else {
                                        $statusText = 'ZAHLUNG OFFEN';
                                    }
