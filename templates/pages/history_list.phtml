    <script>
    const sessionHandler = (function() {
        const MAX_IDLE_TIME = 20 * 60; // 20 Minuten in Sekunden
        const WARNING_TIME = 3 * 60; // 3 Minuten Warnung

        let idleSeconds = 0;
        let countdownInterval;
        let isWarningActive = false;

        const uiTimer = document.getElementById('ui-session-timer');
        const modalTimer = document.getElementById('modal-session-countdown');
        const modal = document.getElementById('session-warning-modal');

        function formatTime(totalSeconds) {
            const m = Math.floor(totalSeconds / 60).toString().padStart(2, '0');
            const s = (totalSeconds % 60).toString().padStart(2, '0');
            return `${m}:${s}`;
        }

        function updateDisplay(remaining) {
            if (uiTimer) {
                uiTimer.innerText = formatTime(remaining);
                uiTimer.style.color = remaining <= WARNING_TIME ? 'var(--danger-color)' : 'var(--text-muted)';
            }
            if (modalTimer && isWarningActive) {
                modalTimer.innerText = formatTime(remaining);
            }
        }

        // Setzt den lokalen Client-Timer bei Bewegung zurück
        function resetIdleTime() {
            if (!isWarningActive) {
                idleSeconds = 0;
                updateDisplay(MAX_IDLE_TIME);
            }
        }

        // Ressourcen-schonend: Belausche nur echte Klicks und Tastenanschläge
        ['click', 'keyup'].forEach(evt =>
            document.addEventListener(evt, resetIdleTime, {
                passive: true
            })
        );

        function tick() {
            idleSeconds++;
            const remaining = MAX_IDLE_TIME - idleSeconds;

            updateDisplay(remaining);

            if (remaining <= WARNING_TIME && remaining > 0 && !isWarningActive) {
                isWarningActive = true;
                modal.style.display = 'flex';
            }

            if (remaining <= 0) {
                clearInterval(countdownInterval);
                logoutNow();
            }
        }

        function stayLoggedIn() {
            // Ping an history.php, um die PHP-Session serverseitig zu verlängern
            fetch(window.KGA_CONFIG.baseUrl + 'history.php?ping=1', {
                    method: 'HEAD'
                })
                .then(() => {
                    idleSeconds = 0;
                    isWarningActive = false;
                    modal.style.display = 'none';
                    updateDisplay(MAX_IDLE_TIME);
                })
                .catch(err => console.error("Konnte Session nicht verlängern", err));
        }

        function logoutNow() {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = window.KGA_CONFIG.baseUrl + 'history.php';

            const actionInput = document.createElement('input');
            actionInput.type = 'hidden';
            actionInput.name = 'action';
            actionInput.value = 'logout';

            const csrfInput = document.createElement('input');
            csrfInput.type = 'hidden';
            csrfInput.name = 'csrf_token';
            csrfInput.value = window.KGA_CONFIG.csrfToken;

            form.appendChild(actionInput);
            form.appendChild(csrfInput);
            document.body.appendChild(form);
            form.submit();
        }

        // Starte den Takt
        countdownInterval = setInterval(tick, 1000);
        updateDisplay(MAX_IDLE_TIME);

        return {
            stayLoggedIn,
            logoutNow
        };
    })();

    </script>
