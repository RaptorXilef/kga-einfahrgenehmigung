                                            <div style="margin-top: 6px;">
                                                <?php if ($isExpired) { ?>
                                                    <span style="color: var(--text-muted); font-size: 0.7rem; font-weight: 800; background: #e2e8f0; padding: 2px 8px; border-radius: 10px;">
                                                        <?php echo $countdownText; ?>
                                                    </span>
                                                <?php } else { ?>
                                                    <span style="color: <?php echo ($remaining <= 1 && ! $isFuture) ? 'var(--danger-color)' : 'var(--primary-color)'; ?>; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; background: <?php echo ($remaining <= 1 && ! $isFuture) ? 'rgba(225, 29, 72, 0.1)' : 'var(--primary-soft)'; ?>; padding: 2px 8px; border-radius: 10px;">
