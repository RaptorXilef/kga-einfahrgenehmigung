 */
// $descOnTop = true;

// --- LOGIK: SORTER & HIERARCHIE ---
$masterPerm      = null;
$globalWildcards = [];
$tree            = [];

\uksort($permissions, function ($a, $b) {
    if ($a === '*') {
        return -1;
    }
    if ($b === '*') {
        return 1;
    }
    $isGlobA = \str_starts_with($a, '*');
    $isGlobB = \str_starts_with($b, '*');
    if ($isGlobA && ! $isGlobB) {
        return -1;
    }
    if (! $isGlobA && $isGlobB) {
        return 1;
    }

    $pA = \explode('.', $a);
    $pB = \explode('.', $b);
    if ($pA[0] === $pB[0] && ($pA[1] ?? '') === ($pB[1] ?? '')) {
        $vA = \str_ends_with($a, '.view');
        $vB = \str_ends_with($b, '.view');
        if ($vA && ! $vB) {
            return -1;
        }
        if (! $vA && $vB) {
            return 1;
        }
    }

    return \strcmp($a, $b);
});

foreach ($permissions as $k => $d) {
    if ($k === '*') {
        $masterPerm = ['k' => $k, 'd' => $d];

        continue;
    }
    if (\str_starts_with($k, '*.')) {
        $globalWildcards[$k] = $d;

        continue;
    }

    $p                     = \explode('.', $k);
    $root                  = $p[0];
    $sub                   = $p[1] ?? 'GENERAL';
    $tree[$root][$sub][$k] = $d;
}
?>
