        <script>
            function massToggle(open) {
                document.querySelectorAll('.category-card').forEach(c => open ? c.classList.remove('is-closed') : c.classList.add('is-closed'));
            }

            /**
             * Abstrakte Engine v0.30.2 (Bugfix Kettenreaktion)
             */
            class PermissionEngine {
                constructor(container) {
                    this.container = container;
                    this.items = Array.from(container.querySelectorAll('.p-item'));
                }

                getActiveExplicit() {
                    return this.items.filter(i => i.querySelector('input[value="allow"]').checked).map(i => i.dataset.perm);
                }

                isCoveredByPattern(targetKey, activePatterns) {
                    for (let pattern of activePatterns) {
                        if (pattern === targetKey) continue;
                        if (pattern === '*') return true;
                        if (pattern.endsWith('.*') && targetKey.startsWith(pattern.slice(0, -1))) return true;
                        if (pattern.startsWith('*.') && targetKey.endsWith(pattern.slice(1))) return true;
                        if (targetKey.endsWith('.view') && pattern.startsWith(targetKey.replace('.view', ''))) return true;
                    }
                    return false;
                }

                refreshVisuals() {
                    const explicit = this.getActiveExplicit();
                    this.items.forEach(item => {
                        const key = item.dataset.perm;
                        const isExplicit = item.querySelector('input[value="allow"]').checked;
                        if (this.isCoveredByPattern(key, explicit) && !isExplicit) {
                            item.classList.add('is-auto-permitted');
                        } else {
                            item.classList.remove('is-auto-permitted');
                        }
                    });
                }

                checkFullCoverage() {
                    const specifics = this.items.filter(i => !i.dataset.perm.startsWith('*') && i.dataset.perm !== '*');
                    const wildcards = this.items.filter(i => i.dataset.perm.startsWith('*.'));
                    const master = this.items.find(i => i.dataset.perm === '*');

                    wildcards.forEach(wItem => {
                        const suffix = wItem.dataset.perm.slice(1);
                        const matchers = specifics.filter(i => i.dataset.perm.endsWith(suffix));
                        if (matchers.length > 0) {
                            const allSet = matchers.every(i => i.querySelector('input[value="allow"]').checked);
                            if (allSet) wItem.querySelector('input[value="allow"]').checked = true;
                        }
                    });

                    if (master) {
                        const allOthersSet = this.items.filter(i => i !== master)
                            .every(i => i.querySelector('input[value="allow"]').checked || i.classList.contains('is-auto-permitted'));
                        if (allOthersSet) master.querySelector('input[value="allow"]').checked = true;
                    }
                }

                applyTopDownRule(triggerKey, state) {
                    if (state !== 'allow') return;
                    this.items.forEach(item => {
                        const k = item.dataset.perm;
                        if (k === triggerKey) return;
                        let shouldSet = false;
                        if (triggerKey === '*') shouldSet = true;
                        else if (triggerKey.endsWith('.*') && k.startsWith(triggerKey.slice(0, -1))) shouldSet = true;
                        else if (triggerKey.startsWith('*.') && k.endsWith(triggerKey.slice(1))) shouldSet = true;
                        if (shouldSet) item.querySelector('input[value="allow"]').checked = true;
                    });
                }

                // Hilfsfunktion um Wildcards zu killen, wenn ein Kind stirbt
                _killParentWildcards(key) {
                    const suffix = key.includes('.') ? '*.' + key.split('.').pop() : null;
                    const prefix = key.includes('.') ? key.split('.').slice(0, -1).join('.') + '.*' : null;

                    this.items.forEach(item => {
                        const k = item.dataset.perm;
                        const radioNone = item.querySelector('input[value="none"]');
                        if (radioNone) {
                            if (k === '*' || (suffix && k === suffix) || (prefix && k === prefix)) {
                                radioNone.checked = true;
                            }
                        }
                    });
                }

                applyBottomUpRule(triggerKey, state) {
                    if (state === 'allow') return;

                    // 1. Wenn ein Recht auf NONE/DENY geht, sterben Master (*) und Suffix/Prefix Wildcards
                    this._killParentWildcards(triggerKey);

                    // 2. Sonderfall: Wenn .view deaktiviert wird, töte alle Aktionen darunter
                    if (triggerKey.endsWith('.view')) {
                        const base = triggerKey.replace('.view', '');
                        this.items.forEach(item => {
                            const k = item.dataset.perm;
                            if (k.startsWith(base) && k !== triggerKey) {
                                const radioNone = item.querySelector('input[value="none"]');
                                if (radioNone && !radioNone.checked) {
                                    radioNone.checked = true;
                                    // WICHTIG: Wenn wir dashboard.active.print ausschalten,
                                    // müssen wir JETZT prüfen, ob *.print auch sterben muss!
                                    this._killParentWildcards(k); // REKURSIVER FIX
                                }
                            }
                        });
                    }
                }

                massReset(state) {
                    if (!confirm("Möchten Sie wirklich alle Rechte dieser Gruppe auf " + state.toUpperCase() + " setzen?")) return;
                    this.items.forEach(item => {
                        const radio = item.querySelector(`input[value="${state}"]`);
                        if (radio) radio.checked = true;
                    });
                    this.refreshVisuals();
                }
            }

            window.engines = {};

            document.querySelectorAll('.permission-container').forEach(c => {
                const groupId = c.dataset.groupId;
                const engine = new PermissionEngine(c);
                window.engines[groupId] = engine;
                engine.refreshVisuals();

                c.querySelectorAll('.p-item input').forEach(radio => {
                    radio.addEventListener('change', (e) => {
                        const item = e.target.closest('.p-item');
                        const key = item.dataset.perm;
                        const val = e.target.value;

                        engine.applyTopDownRule(key, val);
                        engine.applyBottomUpRule(key, val);
                        engine.checkFullCoverage();
                        engine.refreshVisuals();
                    });
                });
            });
        </script>
    </body>

