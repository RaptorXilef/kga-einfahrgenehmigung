    <script>
    function finalizeWire() {
        fetch('<?php echo $settings['base_url']; ?>api/finalize_wire.php?token=<?php echo $token; ?>', {
                headers: {
                    'X-CSRF-Token': '<?php echo $_SESSION['csrf_token'] ?? ''; ?>'
                }
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    window.location.href = 'success.php?code=' + data.code + '&method=wire';
                } else {
                    alert('Fehler beim Abschluss: ' + data.error);
                }
            })
            .catch(err => {
                alert('Ein Netzwerkfehler ist aufgetreten.');
                console.error(err);
            });
    }

    </script>
