    <script>
    const csrfToken = '<?php echo $_SESSION['csrf_token'] ?? ''; ?>';
    const appToken = '<?php echo $token; ?>';

    function finalizeWire() {
        // Token sicher in den POST-Body packen statt in die URL
        const params = new windows.URLSearchParams(); // TODO window. entfernen wenn in JS-Datei
        params.append('token', appToken);
        params.append('csrf_token', csrfToken);

        fetch('<?php echo $settings['base_url']; ?>api/finalize_wire.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-CSRF-Token': csrfToken
                },
                body: params
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    window.location.href = 'success.php?code=' + data.code + '&method=wire';
                } else {
                    alert('Fehler beim Abschluss: ' + data.error);
                }
            })
            .catch(err => {
                alert('Ein Netzwerkfehler ist aufgetreten.');
                console.error(err);
            });
    }

    // PayPal JS Integration (Aktiviert sich nur bei kostenpflichtigen Anträgen)
    <?php if ((float) ($tempData['preis'] ?? 0) > 0.0) { ?>
        if (typeof paypal !== 'undefined') {
            paypal.Buttons({
                createOrder: function(data, actions) {
                    const params = new window.URLSearchParams(); // TODO window. entfernen wenn in JS-Datei
                    params.append('token', appToken);
                    params.append('csrf_token', csrfToken);

                    return fetch('<?php echo $settings['base_url']; ?>api/create_order_for_token.php', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'X-CSRF-Token': csrfToken
                            },
                            body: params
                        })
                        .then(function(res) {
                            return res.json();
                        })
                        .then(function(orderData) {
                            if (orderData.success) {
                                return orderData.id;
                            } else {
                                alert('PayPal-Sitzungsfehler: ' + orderData.error);
                                throw new Error(orderData.error);
                            }
                        });
                },
                onApprove: function(data, actions) {
                    return fetch('<?php echo $settings['base_url']; ?>api/capture.php', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'X-CSRF-Token': csrfToken
                            },
                            body: JSON.stringify({
                                orderID: data.orderID,
                                token: appToken
                            })
                        })
                        .then(function(res) {
                            return res.json();
                        })
                        .then(function(details) {
                            if (details.success) {
                                window.location.href = 'success.php?code=' + appToken +
                                '&method=paypal';
                            } else {
                                alert('Zahlungsverifizierung fehlgeschlagen: ' + details.error);
                            }
                        });
                },
                onError: function(err) {
                    console.error('PayPal-Fehlerkanal:', err);
                    alert('Ein kritischer Fehler ist bei der Zahlungsabwicklung aufgetreten.');
                }
            }).render('#paypal-button-container');
        }
    <?php } ?>

    </script>
