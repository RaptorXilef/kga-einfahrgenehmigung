/**
 * Page: Admin User Liste
 *
 * Path: templates/pages/admin_users/_user_list.phtml
 *
 * @var int                                 $adminLevel
 * @var string                              $adminUser
 * @var array<string, array<string, mixed>> $users
 * @var array<int, string>                  $roles
 */
?>
<section class="c-card u-margin-bottom-xl">
    <header class="c-card__header">
        <h3 class="u-margin-none">👥 Registrierte Konten</h3>
    </header>
    <div class="c-card__body u-padding-none">
        <table class="c-table">
            <thead>
                <tr>
                    <th>Benutzer & Rolle</th>
                    <th>Interne Bezeichnung</th>
                    <th>Sicherheit</th>
                    <th class="u-text-right">Aktionen</th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($users as $name => $u) {
                    $targetLevel = (int) $u['level'];
                    // Nutzt jetzt die globale $adminUser Variable
                    $isSelf = $name === $adminUser;

                    // Nutzt jetzt die globale $adminLevel Variable
                    $canEdit = ($adminLevel === 0) || ($adminLevel === 1 && ($targetLevel > 1 || $isSelf));
                    ?>
                    <tr>
                        <form method="POST">
                            <input type="hidden" name="action" value="save">
                            <input type="hidden" name="username" value="<?php echo \htmlspecialchars($name); ?>">

                            <!-- Benutzer & Rolle -->
                            <td>
                                <div class="u-flex u-flex-column u-gap-xs">
                                    <span class="u-font-bold" style="font-size: 1rem; color: #1e293b;">
                                        <?php echo \htmlspecialchars($name); ?>
                                        <?php if ($isSelf) { ?><span class="u-color-primary" style="font-size: 0.75rem;">(Ich)</span><?php } ?>
                                    </span>
                                    <div>
                                        <?php if ($adminLevel === 0 && ! $isSelf) { ?>
                                            <select name="level" class="c-form-select" style="height: 30px; font-size: 0.75rem; padding: 0 8px; width: auto; display: inline-block;">
                                                <?php foreach ($roles as $lvl => $rName) { ?>
                                                    <option value="<?php echo $lvl; ?>" <?php echo $lvl === $targetLevel ? 'selected' : ''; ?>>
                                                        Lvl <?php echo $lvl; ?>: <?php echo $rName; ?>
                                                    </option>
                                                <?php } ?>
                                            </select>
                                        <?php } else { ?>
                                            <span class="c-role-badge role-<?php echo $targetLevel; ?>">
                                                <?php echo $roles[$targetLevel] ?? $targetLevel; ?>
                                            </span>
                                            <input type="hidden" name="level" value="<?php echo $targetLevel; ?>">
                                        <?php } ?>
                                    </div>
                                </div>
                            </td>

                            <!-- Bezeichnung -->
                            <td>
                                <input type="text" name="label"
                                    value="<?php echo \htmlspecialchars($u['label'] ?? ''); ?>"
                                    class="c-form-input"
                                    style="height: 36px; font-size: 0.9rem;"
                                    placeholder="z.B. Vorname"
                                    <?php echo ! $canEdit ? 'disabled' : ''; ?>>
                            </td>

                            <!-- Passwort -->
                            <td>
                                <input type="password" name="password"
                                    placeholder="Passwort ändern..."
                                    class="c-form-input"
                                    style="height: 36px; font-size: 0.9rem;"
                                    <?php echo ! $canEdit ? 'disabled' : ''; ?>>
                            </td>

                            <!-- Aktionen -->
                            <td class="u-text-right">
                                <div class="u-flex u-gap-xs u-justify-end">
                                    <?php if ($canEdit) { ?>
                                        <button type="submit" class="c-button c-button--primary" style="padding: 8px 12px;" title="Speichern"><img src="<?php echo $settings['base_url']; ?>assets/img/icons/action-save.webp" class="c-icon" alt=""><!-- 💾 --></button>
                                        <?php if (! $isSelf) { ?>
                                            <button type="submit" name="action" value="delete"
                                                class="c-button c-button--danger"
                                                style="padding: 8px 12px;"
                                                onclick="return confirm('Benutzer wirklich löschen?')"><img src="<?php echo $settings['base_url']; ?>assets/img/icons/action-delete.webp" class="c-icon" alt=""><!-- 🗑️ --></button>
                                        <?php } ?>
                                    <?php } else { ?>
                                        <span class="u-text-muted u-text-small">Nur Lesezugriff</span>
                                    <?php } ?>
                                </div>
                            </td>
                        </form>
                    </tr>
                <?php } ?>
            </tbody>
        </table>
    </div>
</section>
