    <script>
        const templates = <?php echo \json_encode($tplMetadata); ?>;
        const inputVon = document.getElementById('datum_von');
        const inputBis = document.getElementById('datum_bis');
        const inputParzelle = document.getElementById('parzelle');
        const selectTpl = document.getElementById('template_key');
        const selectTyp = document.getElementById('typ');
        const firmaWrapper = document.getElementById('u_firma_wrapper');
        const inputKennzeichen = document.getElementById('kennzeichen');
        const labelKennzeichen = document.getElementById('label_kennzeichen');
        const warningBox = document.getElementById('date-warning');
        const warningText = document.getElementById('date-warning-text');

        // Gutschein aktiv wenn $prefill Daten hat
        const isVoucherActive = <?php echo $prefill ? 'true' : 'false'; ?>;

        // Heute als Basis
        const today = new Date();
        const todayStr = today.toISOString().split('T')[0];
        // Erlaube keine Daten in der Vergangenheit
        inputVon.min = todayStr;

        function toggleVoucher() {
            document.getElementById('voucher-container').classList.toggle('is-open');
        }

        // Logik für Firma und Kennzeichen-Validierung
        function toggleFirmaField() {
            if (selectTyp.value === 'lkw') {
                firmaWrapper.classList.remove('u-hidden');
                labelKennzeichen.innerText = "Amtl. Kennzeichen (Optional)";
                inputKennzeichen.required = false;
            } else {
                firmaWrapper.classList.add('u-hidden');
                labelKennzeichen.innerText = "Amtl. Kennzeichen";
                inputKennzeichen.required = true;
                document.getElementById('u_firma').value = '';
            }
        }

        /**
         * Automatische Parzellen-Formatierung (0001)
         * Wird nur ausgeführt, wenn KEIN Gutschein das Feld gesperrt hat.
         */
        inputParzelle.addEventListener('blur', (e) => {
            if (e.target.value && !e.target.readOnly) {
                e.target.value = e.target.value.toString().padStart(4, '0');
            }
        });

        /**
         * Intelligente Kennzeichen-Formatierung  mit Manual Override (inkl. E- und H-Unterstützung)
         */
        inputKennzeichen.addEventListener('blur', (e) => {
            if (e.target.readOnly) return;

            let val = e.target.value.toUpperCase().trim();
            if (val.length <= 3) return;

            // Wenn Nutzer ein Minus tippt -> Nur Buchstaben/Zahlen-Lücke fixen
            if (val.includes('-')) {
                e.target.value = val.replace(/([A-Z])([0-9])/, '$1 $2');
                return;
            }

            // Automatik-Modus ohne manuellen Bindestrich
            let clean = val.replace(/[^A-Z0-9]/g, '');

            // RegEx erweitert um [EH]? am Ende
            const pattern4 = /^([A-Z]{2})([A-Z]{2})([0-9]{1,4}[EH]?)$/;
            const berlinPattern = /^(B)([A-Z]{1,2})([0-9]{1,4}[EH]?)$/;
            const complexPattern = /^([A-Z]{1,3})([A-Z]{1,2})([0-9]{1,4}[EH]?)$/;
            const fallbackPattern = /^([A-Z]{1,3})([0-9]{1,4}[EH]?)$/;

            if (pattern4.test(clean)) {
                e.target.value = clean.replace(pattern4, '$1-$2 $3');
            } else if (berlinPattern.test(clean)) {
                e.target.value = clean.replace(berlinPattern, '$1-$2 $3');
            } else if (complexPattern.test(clean)) {
                e.target.value = clean.replace(complexPattern, '$1-$2 $3');
            } else if (fallbackPattern.test(clean)) {
                e.target.value = clean.replace(fallbackPattern, '$1 $2');
            }
        });

        function handleDateChange(source) {
            // Wenn das Feld readonly ist (durch festen Gutschein-Zeitraum), Logik überspringen
            if (source === 'bis' && inputBis.readOnly) return;
            if (source === 'von' && inputVon.readOnly) return;

            const config = templates[selectTpl.value];
            if (!config) return;

            const isCustom = config.days === 'custom';
            const duration = isCustom ? 0 : parseInt(config.days);

            warningBox.style.display = 'none';

            if (!isCustom) {
                // 1. Berechnung des frühestmöglichen BIS-Datums (Heute + Dauer)
                let minBisDate = new Date(today);
                minBisDate.setDate(minBisDate.getDate() + duration);
                const minBisStr = minBisDate.toISOString().split('T')[0];

                // Sperre im Kalender setzen
                inputBis.min = minBisStr;

                if (source === 'bis') {
                    // BIS wurde geändert -> Berechne VON (BIS - Dauer)
                    if (inputBis.value < minBisStr) {
                        inputBis.value = minBisStr;
                        warningText.innerText = "Das Datum wurde auf die Mindestdauer der Vorlage korrigiert.";
                        warningBox.style.display = 'block';
                    }

                    let d = new Date(inputBis.value);
                    d.setDate(d.getDate() - duration);
                    inputVon.value = d.toISOString().split('T')[0];

                } else {
                    // VON oder Template wurde geändert -> Berechne BIS (VON + Dauer)
                    if (inputVon.value < todayStr) {
                        inputVon.value = todayStr;
                    }

                    let d = new Date(inputVon.value);
                    d.setDate(d.getDate() + duration);
                    inputBis.value = d.toISOString().split('T')[0];
                }
            } else {
                // Logik für Spezialzeitraum (Custom)
                inputBis.min = inputVon.value;
                if (inputBis.value < inputVon.value) inputBis.value = inputVon.value;
            }
        }

        // Preis-Update via API
        async function updatePrice() {
            try {
                // Wir suchen den Voucher-Wert. Zuerst das Textfeld, falls leer das versteckte Feld.
                const inputField = document.querySelector('input[type="text"][name="voucher"]');
                const hiddenField = document.querySelector('input[type="hidden"][name="voucher"]');
                const voucher = (inputField && inputField.value) ? inputField.value : (hiddenField ? hiddenField.value : '');

                const res = await fetch(window.KGA_CONFIG.baseUrl + `api/get_template_price.php?key=${selectTpl.value}&typ=${selectTyp.value}&voucher=${voucher}`);

                if (!res.ok) throw new Error('Server-Antwort nicht okay');

                const data = await res.json();
                const priceBox = document.getElementById('price-display');

                if (data.discountText && data.discountText !== '') {
                    priceBox.innerHTML = `
                        <div class="c-price-original">Original: ${data.original.toFixed(2).replace('.', ',')} €</div>
                        <div>Gebühr: ${data.formatted}</div>
                        <div class="c-price-discount-hint">${data.discountText} angewendet</div>
                    `;
                } else {
                    priceBox.innerText = `Gebühr: ${data.formatted}`;
                }

                priceBox.style.color = data.isFree ? '#059669' : 'var(--primary-color)';
                priceBox.style.background = data.isFree ? '#ecfdf5' : 'var(--primary-soft)';

            } catch (error) {
                console.error("Preisberechnung fehlgeschlagen:", error);
                document.getElementById('price-display').innerText = "Gebühr: --,-- €";
            }
        }

        // Event-Listener
        selectTpl.addEventListener('change', () => {
            handleDateChange('template');
            updatePrice();
        });
        inputVon.addEventListener('change', () => {
            handleDateChange('von');
            updatePrice();
        });
        inputBis.addEventListener('change', () => {
            handleDateChange('bis');
            updatePrice();
        });
        selectTyp.addEventListener('change', () => {
            toggleFirmaField();
            updatePrice();
        });

        // Initialisierung
        toggleFirmaField();
        handleDateChange('init');
        updatePrice(); // Direkt beim Laden aufrufen

        // Falls ein Gutschein in der URL steht, aber kein $prefill aktiv ist (z.B. Fehlermeldung)
        // öffnen wir das Eingabefeld automatisch, damit der User den Code sieht/korrigieren kann.
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('voucher') && !isVoucherActive) {
            toggleVoucher();
        }
    </script>
</body>

</html>
