// Initialisierung der Variable, falls sie vom Controller vergessen wurde
$prefill ??= null;

// Hilfsfunktion: Prüft ob ein Feld durch Gutschein gesperrt ist
$isLocked = function ($fieldName) use ($prefill) {
    if ($prefill === null || ! isset($prefill['data'])) {
        return '';
    }

    return (isset($prefill['data'][$fieldName]) && $prefill['data'][$fieldName] !== '') ? 'readonly' : '';
};
?>
