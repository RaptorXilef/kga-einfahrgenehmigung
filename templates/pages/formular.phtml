    <script>
        const templates = <?php echo \json_encode($tplMetadata); ?>;
        const inputVon = document.getElementById('datum_von');
        const inputBis = document.getElementById('datum_bis');
        const selectTpl = document.getElementById('template_key');

        // PHP gibt uns mit, ob ein Gutschein geladen ist
        const isVoucherActive = <?php echo $prefill ? 'true' : 'false'; ?>;

        function toggleVoucher() {
            document.getElementById('voucher-container').classList.toggle('is-open');
        }

        function handleDateChange(source) {
            const config = templates[selectTpl.value];
            if (!config || config.days === 'custom') return;
            const duration = parseInt(config.days);

            if (source === 'von' && inputVon.value) {
                let d = new Date(inputVon.value);
                d.setDate(d.getDate() + duration);
                inputBis.value = d.toISOString().split('T')[0];
            } else if (source === 'bis' && inputBis.value) {
                let d = new Date(inputBis.value);
                d.setDate(d.getDate() - duration);
                inputVon.value = d.toISOString().split('T')[0];
            }
        }

        selectTpl.addEventListener('change', () => handleDateChange('von'));
        inputVon.addEventListener('change', () => handleDateChange('von'));
        inputBis.addEventListener('change', () => handleDateChange('bis'));
        handleDateChange('von');

        // Preis-Update via API
        async function updatePrice() {
            // Wenn Gutschein aktiv, immer 0,00 € anzeigen!
            if (isVoucherActive) {
                const priceBox = document.getElementById('price-display');
                priceBox.innerText = `Gebühr: 0,00 € (Gutschein)`;
                priceBox.style.color = '#10b981'; // Grün für kostenlos
                priceBox.style.background = '#ecfdf5';
                priceBox.style.borderColor = '#a7f3d0';
                return;
            }

            const typ = document.getElementById('typ').value;
            const res = await fetch(`api/get_template_price.php?key=${selectTpl.value}&typ=${typ}`);
            const data = await res.json();
            document.getElementById('price-display').innerText = `Gebühr: ${data.formatted}`;
        }

        selectTpl.addEventListener('change', updatePrice);
        document.getElementById('typ').addEventListener('change', updatePrice);
        updatePrice(); // Direkt beim Laden aufrufen
    </script>
