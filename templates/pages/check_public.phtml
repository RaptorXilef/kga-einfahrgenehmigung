<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gültigkeitsprüfung</title>
    <link rel="stylesheet" href="assets/css/main.min.css">
</head>
<body class="l-check u-bg-light">
    <main class="c-container u-text-center u-padding-top-xl">

        <?php if ($permit->isValid()): ?>
            <div class="c-card c-card--success u-margin-auto" style="max-width: 400px;">
                <div class="c-card__header">
                    <span class="u-font-xl">✅ GÜLTIG</span>
                </div>
                <div class="c-card__body">
                    <div class="u-margin-bottom">
                        <strong>Fahrzeug / Identifikation:</strong><br>
                        <?php
                            $display = [];
                            if (!empty($permit->kennzeichen)) $display[] = htmlspecialchars($permit->kennzeichen);
                            if (!empty($permit->firma)) $display[] = "Firma: " . htmlspecialchars($permit->firma);
                            echo implode('<br>', $display);
                        ?>
                    </div>
                    <div class="u-text-muted">
                        Zeitraum: <?= $permit->von->format('d.m.Y') ?> bis <?= $permit->bis->format('d.m.Y') ?>
                    </div>
                </div>
            </div>
        <?php else: ?>
            <div class="c-card c-card--danger u-margin-auto" style="max-width: 400px;">
                <div class="c-card__header">
                    <span class="u-font-xl">❌ UNGÜLTIG</span>
                </div>
                <div class="c-card__body">
                    <p>Diese Genehmigung ist abgelaufen, noch nicht gültig oder wurde gesperrt.</p>
                </div>
            </div>
        <?php endif; ?>

        <footer class="u-margin-top-l">
            <p class="u-text-small u-text-muted">Code: <?= htmlspecialchars($permit->code) ?></p>
        </footer>
    </main>
</body>
</html>
