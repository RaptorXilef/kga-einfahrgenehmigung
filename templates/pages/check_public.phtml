?>
<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Status-Check - <?php echo \htmlspecialchars($settings['vereins_name']); ?></title>
    <link rel="stylesheet" href="assets/css/main.min.css">
</head>

<body class="l-check u-bg-light">
    <?php include $appRoot . '/templates/partials/test_mode_indicator.phtml'; ?>

    <main class="c-container u-text-center u-padding-top-xl">

        <?php
        // 1. FALL: PERMIT EXISTIERT BEREITS (AKTIV ODER GESPERRT)
        if ($permit) {
            if ($permit->isSuspended) { ?>
                <div class="c-card c-card--danger u-margin-auto" style="border: 8px solid #c0392b; max-width: 500px;">
                    <div class="c-card__header" style="background: #c0392b; color: #fff; padding: 20px;">
                        <span style="font-size: 50px;">🚫</span>
                        <h2 style="margin: 10px 0; color:#fff;">ZUTRITT VERWEIGERT</h2>
                    </div>
                    <div class="c-card__body">
                        <p class="u-font-bold u-font-l">Diese Genehmigung wurde dauerhaft gesperrt!</p>
                        <?php if ($permit->suspensionReason) { ?>
                            <div style="background: #fdeaea; padding: 15px; border: 1px solid #ebccd1; margin-top: 15px; border-radius: 5px;">
                                <strong>Grund der Sperre:</strong><br>
                                <?php echo \htmlspecialchars($permit->suspensionReason); ?>
                            </div>
                        <?php } ?>
                        <p class="u-margin-top-m u-text-small">Bitte wenden Sie sich an die Vereinsverwaltung.</p>
                    </div>
                </div>

            <?php } elseif ($isDateValid && $isTimeAllowed) { ?>
                <div class="c-card c-card--success u-margin-auto" style="max-width: 450px; border: 5px solid #27ae60;">
                    <div class="c-card__header">
                        <span style="font-size: 40px; display:block;">✅</span>
                        <span class="u-font-xl">GENEHMIGUNG GÜLTIG</span>
                    </div>
                    <div class="c-card__body">
                        <?php include '_check_details.phtml'; ?>
                    </div>
                </div>

            <?php } elseif ($isDateValid && ! $isTimeAllowed) { ?>
                <div class="c-card u-margin-auto" style="max-width: 450px; border: 5px solid #e67e22; background: #fff5e6;">
                    <div class="c-card__header"><span class="u-font-xl" style="color: #d35400;">⏳ RUHEZEIT</span></div>
                    <div class="c-card__body">
                        <p>Die Genehmigung ist heute <strong>gültig</strong>, aber aktuell ist <strong>Ruhezeit</strong>.</p>
                        <p>Einfahrt erst wieder: <strong><?php echo $allowedToday; ?></strong></p>
                        <hr style="opacity: 0.2; margin: 15px 0;">
                        <?php include '_check_details.phtml'; ?>
                    </div>
                </div>

            <?php } else { ?>
                <div class="c-card c-card--danger u-margin-auto" style="max-width: 400px;">
                    <div class="c-card__header"><span class="u-font-xl">❌ UNGÜLTIG</span></div>
                    <div class="c-card__body">
                        <p>Keine gültige Genehmigung für den heutigen Tag gefunden oder der Zeitraum ist abgelaufen.</p>
                    </div>
                </div>
            <?php } ?>

        <?php
            // 2. FALL: ZAHLUNGSPROZESS (TEMPDATA VORHANDEN)
        } elseif ($tempData && $token) { ?>
            <section class="c-card u-margin-top-l u-margin-auto" style="max-width: 450px; border-top: 4px solid #3498db;">
                <header class="c-card__header">
                    <h3>Zahlung abschließen</h3>
                    <p class="u-text-small">Wählen Sie eine Zahlungsart zur Aktivierung:</p>
                </header>

                <div class="c-card__body">
                    <?php if ($config->get('paypal')['enabled']) { ?>
                        <div id="paypal-button-container" class="u-padding-y-m"></div>
                        <script src="https://www.paypal.com/sdk/js?client-id=<?php echo $config->isTestMode() ? $config->get('paypal')['sandbox']['client_id'] : $config->get('paypal')['live']['client_id']; ?>&currency=EUR"></script>
                        <script>
                            paypal.Buttons({
                                createOrder: () => fetch('api/create_order_for_token.php?token=<?php echo $token; ?>').then(r => r.json()).then(data => data.id),
                                onApprove: (data) => fetch('api/capture.php', {
                                        method: 'POST',
                                        headers: {
                                            'Content-Type': 'application/json'
                                        },
                                        body: JSON.stringify({
                                            orderID: data.orderID,
                                            token: '<?php echo $token; ?>'
                                        })
                                    })
                                    .then(r => r.json()).then(res => {
                                        if (res.success) window.location.href = 'check.php?token=<?php echo $token; ?>&success=1';
                                        else alert('Fehler: ' + res.message);
                                    })
                            }).render('#paypal-button-container');
                        </script>
                    <?php } ?>
                    <div class="u-margin-top-l u-text-center">
                        <p class="u-text-small">Oder per Überweisung (Dauer 2-3 Tage)</p>
                        <button onclick="finalizeWire()" class="c-button c-button--secondary c-button--small">Überweisung verbindlich abschließen</button>
                    </div>
                </div>
            </section>
            <script>
                function finalizeWire() {
                    if (!confirm('Hiermit bestätigen Sie, dass Sie den Betrag zeitnah überweisen werden.')) return;
                    fetch('api/finalize_wire.php?token=<?php echo $token; ?>').then(r => r.json()).then(data => {
                        if (data.success) window.location.href = 'check.php?code=' + data.code + '&wire=1';
                        else alert('Fehler: ' + data.error);
                    });
                }
            </script>

        <?php
            // 3. FALL: GAR NICHTS GEFUNDEN
        } else { ?>
            <div class="c-card c-card--danger u-margin-auto" style="max-width: 400px;">
                <p>Ungültiger Zugriff oder Sitzung abgelaufen.</p>
            </div>
        <?php } ?>

        <?php
        // ADMIN-LOGIN LINK (NUR WENN NICHT SCHON IN ADMIN-ANSICHT)
        if (! isset($showAdminView) && $permit) { ?>
            <div class="u-margin-top-l">
                <a href="admin.php?redirect_to_code=<?php echo $permit->code; ?>" class="u-text-small">Vorstands-Login für Details</a>
            </div>
        <?php } ?>

        <?php if ($permit) { ?>
            <footer class="u-margin-top-l">
                <p class="u-text-muted">SmartCode: <?php echo \htmlspecialchars($permit->code); ?></p>
            </footer>
        <?php } ?>
    </main>
</body>

</html>
