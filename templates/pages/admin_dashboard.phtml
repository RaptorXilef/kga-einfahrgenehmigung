    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const banner = document.getElementById('github-update-banner');
        const versionLabel = document.getElementById('gh-version');
        const notesLabel = document.getElementById('gh-notes');
        const installBtn = document.getElementById('gh-install-btn');
        const releaseLink = document.getElementById('gh-release-link');
        let downloadUrl = '';

        // 1. Im Hintergrund prüfen, ob ein Update da ist
        fetch('<?php echo $settings['base_url'] ?? '/'; ?>api/check_update.php')
            .then(res => res.json())
            .then(data => {
                if (data.success && data.update_available) {
                    downloadUrl = data.data.zipball_url;
                    versionLabel.innerText = data.data.version;

                    // Release Notes dynamisch verlinken
                    releaseLink.href = 'https://github.com/RaptorXilef/kga-einfahrgenehmigung/releases/tag/' + data.data.version;

                    if (data.data.name) notesLabel.innerText = "Release: " + data.data.name;
                    banner.classList.remove('u-hidden');
                }
            })
            .catch(err => console.error('Update-Check fehlgeschlagen:', err));

        // 2. Klick auf den Installieren-Button
        if (installBtn) {
            installBtn.addEventListener('click', () => {
                if (!confirm(
                        'Möchten Sie das Update jetzt durchführen? Das System wird für wenige Sekunden nicht erreichbar sein.'
                    )) return;

                installBtn.innerHTML = '⏳ Installiere... Bitte warten!';
                installBtn.disabled = true;
                installBtn.style.opacity = '0.7';

                fetch('<?php echo $settings['base_url'] ?? '/'; ?>api/perform_update.php', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-Token': '<?php echo $_SESSION['csrf_token'] ?? ''; ?>'
                        },
                        body: JSON.stringify({
                            zip_url: downloadUrl
                        })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            alert('🎉 Update erfolgreich installiert!');
                            window.location.reload();
                        } else {
                            alert('❌ Fehler beim Update: ' + data.error);
                            installBtn.innerHTML = 'Update fehlgeschlagen';
                        }
                    })
                    .catch(err => {
                        alert('Netzwerkfehler beim Update.');
                        installBtn.innerHTML = 'Erneut versuchen';
                        installBtn.disabled = false;
                        installBtn.style.opacity = '1';
                    });
            });
        }
    });

    </script>

