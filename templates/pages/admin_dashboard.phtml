        <script>
        document.addEventListener('DOMContentLoaded', () => {
            const banner = document.getElementById('github-update-banner');
            const versionLabel = document.getElementById('gh-version');
            const notesLabel = document.getElementById('gh-notes');
            const installBtn = document.getElementById('gh-install-btn');
            const releaseLink = document.getElementById('gh-release-link');

            // Wir rendern dynamisch einen "Neu laden" Button neben den Install-Button
            let checkBtn = null;
            if (installBtn) {
                checkBtn = document.createElement('button');
                // Keine Standard-Klassen, sondern exakt auf das Banner abgestimmtes Design:
                checkBtn.style.cssText =
                    'background: rgba(59, 130, 246, 0.1); color: #1e40af; border: 1px solid rgba(59, 130, 246, 0.3); padding: 8px 16px; margin-top: 10px; font-size: 0.85rem; width: 100%; border-radius: 4px; cursor: pointer; transition: all 0.2s; font-weight: 600; display: inline-flex; justify-content: center; align-items: center; gap: 6px;';

                checkBtn.onmouseover = () => checkBtn.style.background = 'rgba(59, 130, 246, 0.2)';
                checkBtn.onmouseout = () => checkBtn.style.background = 'rgba(59, 130, 246, 0.1)';

                checkBtn.innerHTML = '🔄 Auf Updates prüfen';

                checkBtn.onclick = (e) => {
                    e.preventDefault();
                    checkBtn.innerText = 'Prüfe...';
                    checkBtn.disabled = true;
                    performCheck(true);
                };
                installBtn.parentNode.appendChild(checkBtn);
            }

            // 1. Im Hintergrund prüfen, ob ein Update da ist
            // CSRF-Header hinzugefügt, da die API nun gehärtet ist
            function performCheck(force = false) {
                fetch('<?php echo $settings['base_url'] ?? '/'; ?>api/check_update.php', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-CSRF-Token': window.KGA_CONFIG.csrfToken
                        },
                        body: JSON.stringify({
                            force: force
                        })
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (checkBtn) {
                            checkBtn.innerText = '🔄 Auf neuere Version';
                            checkBtn.disabled = false;
                        }

                        if (data.success && data.update_available) {
                            versionLabel.innerText = data.data.version;

                            // Release Notes dynamisch verlinken
                            releaseLink.href =
                                'https://github.com/RaptorXilef/kga-einfahrgenehmigung/releases/tag/' + data
                                .data.version;

                            // NEU: Setze die Download-URL als Data-Attribut für den JS-Handler
                            if (installBtn) {
                                installBtn.setAttribute('data-url', data.data.zipball_url);
                            }

                            if (data.data.name) notesLabel.innerText = "Release: " + data.data.name;
                            banner.classList.remove('u-hidden');
                        } else if (force) {
                            alert('Das System ist aktuell. Es wurden keine neuen Versionen gefunden.');
                        }
                    })
                    .catch(err => {
                        console.error('Update-Check fehlgeschlagen:', err);
                        if (checkBtn) {
                            checkBtn.innerText = 'Fehler beim Prüfen';
                            checkBtn.disabled = false;
                        }
                    });
            }

            // Beim Laden der Seite normalen (gecachten) Check ausführen
            performCheck(false);
        });

        </script>
    <?php } ?>

