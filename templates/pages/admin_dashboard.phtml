// --- Aktuelle Version aus package.json auslesen ---
$currentVersion  = 'v0.0.0';
$packageJsonPath = $appRoot . '/package.json';
if (\file_exists($packageJsonPath)) {
    $pkgContent = \file_get_contents($packageJsonPath);
    if ($pkgContent !== false) {
        $pkgData = \json_decode($pkgContent, true);
        if (\is_array($pkgData) && isset($pkgData['version'])) {
            $currentVersion = 'v' . $pkgData['version'];
        }
    }
}
