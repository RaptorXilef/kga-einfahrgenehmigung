        // Variablen für das Sub-Template vorbereiten (müssen manuell gemappt werden, da wir nicht im Service sind)
        $opening = $settings['opening_hours'];
        $data = [
            'fullIdentifier'    => $permit->code,
            'von'               => $permit->von->format('d.m.Y'),
            'bis'               => $permit->bis->format('d.m.Y'),
            'kennzeichen'       => $permit->kennzeichen,
            'firma'             => $permit->firma,
            'parzelle'          => $permit->parzelle,
            'zweck'             => $settings['purposes'][$permit->zweck] ?? $permit->zweck,
            'vereinsName'       => $settings['vereins_name'],
            'jahresFarbe'       => $settings['jahresFarbe'],
            'opening'           => "{$opening['earliest']} bis {$opening['latest']} Uhr",
            'terminkalenderUrl' => $settings['terminkalender_url'],
            'erstellt'          => $permit->erstellt->format('d.m.Y H:i'),
            'checkUrl'          => $settings['base_url'] . "check.php?code=" . $permit->code
        ];

        // Wir lesen das Template ein und ersetzen die Platzhalter
        $templatePath = $appRoot . '/templates/emails/permit_a4_document.phtml';
        $content = \file_get_contents($templatePath);

        foreach ($data as $key => $value) {
            $content = \str_replace('{{' . $key . '}}', (string)$value, $content);
        }

        // Da das Template evtl. PHP-Code enthält (z.B. für die Firma-Weiche), nutzen wir eval oder laden es sauber:
        // Wir nutzen hier die saubere Integration:
        extract($data);
        include $appRoot . '/templates/emails/permit_a4_document.phtml';
    ?>
