<?php
/**
 * @var array<string, mixed>                $settings
 * @var \App\Infrastructure\Config\Config   $config
 * @var string                              $appRoot
 * @var string                              $message
 * @var int                                 $myLevel
 * @var string                              $myUsername
 * @var array<string, array<string, mixed>> $users
 * @var array<int, string>                  $roles
 */
?>
<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Benutzerverwaltung - <?php echo \htmlspecialchars($settings['vereins_name']); ?></title>
    <link rel="stylesheet" href="assets/css/main.min.css">
</head>
<body class="l-admin">
    <?php include $appRoot . '/templates/partials/test_mode_indicator.phtml'; ?>

    <nav class="c-admin-nav">
        <div class="c-container">
            <a href="admin.php">← Zurück zum Dashboard</a>
            <span class="u-float-right">Angemeldet als: <strong><?php echo $roles[$myLevel] ?? 'User'; ?></strong></span>
        </div>
    </nav>

    <main class="c-container u-padding-y-l">
        <h1>Benutzerverwaltung</h1>

        <?php if ($message) { ?>
            <div class="c-alert c-alert--info"><?php echo \htmlspecialchars($message); ?></div>
        <?php } ?>

        <section class="c-card">
            <table class="c-table">
                <thead>
                    <tr>
                        <th>Benutzername</th>
                        <th>Rolle / Level</th>
                        <th>Interne Bezeichnung</th>
                        <th>Neues Passwort</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($users as $name => $u) {
                        $targetLevel = (int) $u['level'];
                        $isSelf      = $name === $myUsername;
                        // Darf ich editieren? (Superadmin darf alles, Admin darf >= Level 2 oder sich selbst)
                        $canEdit = ($myLevel === 0) || ($myLevel === 1 && ($targetLevel > 1 || $isSelf));
                        ?>
                    <tr>
                        <form method="POST">
                            <input type="hidden" name="action" value="save">
                            <input type="hidden" name="username" value="<?php echo \htmlspecialchars($name); ?>">

                            <td>
                                <strong><?php echo \htmlspecialchars($name); ?></strong>
                                <?php echo $isSelf ? '<br><small class="u-color-primary">(Das sind Sie)</small>' : ''; ?>
                            </td>

                            <td>
                                <?php if ($myLevel === 0 && ! $isSelf) { ?>
                                    <select name="level" class="c-form-select c-form-select--small">
                                        <?php foreach ($roles as $lvl => $rName) { ?>
                                            <option value="<?php echo $lvl; ?>" <?php echo $lvl === $targetLevel ? 'selected' : ''; ?>>
                                                <?php echo $lvl; ?>: <?php echo $rName; ?>
                                            </option>
                                        <?php } ?>
                                    </select>
                                <?php } else { ?>
                                    <span class="c-badge"><?php echo $roles[$targetLevel] ?? $targetLevel; ?></span>
                                    <input type="hidden" name="level" value="<?php echo $targetLevel; ?>">
                                <?php } ?>
                            </td>

                            <td>
                                <input type="text" name="label" value="<?php echo \htmlspecialchars($u['label'] ?? ''); ?>"
                                       class="c-form-input c-form-input--small" <?php echo ! $canEdit ? 'disabled' : ''; ?>>
                            </td>

                            <td>
                                <input type="password" name="password" placeholder="Nur zum Ändern füllen"
                                       class="c-form-input c-form-input--small" <?php echo ! $canEdit ? 'disabled' : ''; ?>>
                            </td>

                            <td>
                                <?php if ($canEdit) { ?>
                                    <button type="submit" class="c-button c-button--small">💾</button>
                                    <?php if (! $isSelf) { ?>
                                        <button type="submit" name="action" value="delete"
                                                class="c-button c-button--small c-button--danger"
                                                onclick="return confirm('Löschen?')">🗑</button>
                                    <?php } ?>
                                <?php } else { ?>
                                    <span class="u-text-muted">Gesperrt</span>
                                <?php } ?>
                            </td>
                        </form>
                    </tr>
                    <?php } ?>
                </tbody>
            </table>
        </section>

        <section class="c-card u-margin-top-l">
            <header class="c-card__header"><h3>Neuen Benutzer anlegen</h3></header>
            <form method="POST" class="u-flex u-gap-s u-align-end">
                <input type="hidden" name="action" value="save">
                <div class="c-form-group">
                    <label class="c-form-label">Username</label>
                    <input type="text" name="username" class="c-form-input" required>
                </div>
                <div class="c-form-group">
                    <label class="c-form-label">Passwort</label>
                    <input type="password" name="password" class="c-form-input" required>
                </div>
                <div class="c-form-group">
                    <label class="c-form-label">Rolle</label>
                    <select name="level" class="c-form-select">
                        <?php foreach ($roles as $lvl => $rName) {
                            // Admin (1) darf nur Level 2 und 3 erstellen
                            if ($myLevel === 1 && $lvl <= 1) {
                                continue;
                            } // Admin darf keine Admins/Superadmins bauen
                            ?>
                            <option value="<?php echo $lvl; ?>"><?php echo $lvl; ?>: <?php echo $rName; ?></option>
                        <?php } ?>
                    </select>
                </div>
                <button type="submit" class="c-button">Benutzer erstellen</button>
            </form>
        </section>
    </main>
</body>
</html>
