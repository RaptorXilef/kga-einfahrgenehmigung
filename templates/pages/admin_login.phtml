    <script>
    // Auge-Icon Toggle-Funktion
    function togglePassword(event) {
        const input = document.getElementById('login_pass');
        const btn = event.currentTarget;
        if (input.type === 'password') {
            input.type = 'text';
            btn.style.opacity = '1';
        } else {
            input.type = 'password';
            btn.style.opacity = '0.5';
        }
    }

    // Sauberer Heartbeat: Sendet einen POST-Request an den dedizierten Ping-Endpunkt,
    // inkl. Cookies, um die Session zuverlässig vor dem Timeout zu bewahren.
    setInterval(() => {
        fetch(window.KGA_CONFIG.baseUrl + 'api/ping.php', {
            method: 'POST',
            credentials: 'include'
        }).catch(() => console.debug('Session Ping fehlgeschlagen'));
    }, 3 * 60 * 1000); // Alle 3 Minuten

    </script>
