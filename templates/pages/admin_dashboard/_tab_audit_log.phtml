<script>
    // Tab automatisch aktivieren, wenn Paginierung oder Filter im Audit-Log genutzt wird
    document.addEventListener('DOMContentLoaded', () => {
        // FIX: window.URLSearchParams verhindert falsche Linter-Warnungen
        const urlParams = new window.URLSearchParams(window.location.search); // TODO .window von window.URLSearchParams entfernen, wenn in JS-Datei
        if (urlParams.has('audit_page') || urlParams.has('audit_filter')) {
            const auditBtn = document.querySelector('[data-tab-target="tab-audit-log"]');
            if (auditBtn && window.adminHandlerInstance) {
                window.adminHandlerInstance.switchTab('tab-audit-log', auditBtn);
            }
        }
    });
</script>
