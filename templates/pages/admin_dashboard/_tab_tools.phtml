<script>
    /**
     * INTELLIGENTE DATUMS-LOGIK (v2.0)
     */
    const templates = <?php echo \json_encode($tplMetadata); ?>;
    const inputVon = document.getElementById('u_datum_von');
    const inputBis = document.getElementById('u_datum_bis');
    const selectTpl = document.getElementById('u_template_key');
    const warningBox = document.getElementById('date-warning');
    const warningText = document.getElementById('date-warning-text');

    function showDateWarning(msg) {
        if (!msg) {
            warningBox.style.display = 'none';
            return;
        }
        warningText.innerText = msg;
        warningBox.style.display = 'block';
    }

    function getTodayStr() {
        return new Date().toISOString().split('T')[0];
    }

    function updateDates(sourceField) {
        const tplKey = selectTpl.value;
        const config = templates[tplKey];
        const today = getTodayStr();

        showDateWarning(null);

        // Spezialzeitraum: Beide Felder sind frei wählbar
        if (config.days === 'custom') {
            inputBis.readOnly = false;
            inputVon.readOnly = false;
            inputBis.style.background = '#fff';
            return;
        }

        // Fixer Zeitraum: Berechnungen
        inputBis.readOnly = (sourceField === 'von'); // Wenn wir "Von" ändern, berechnen wir "Bis" (Readonly)
        inputVon.readOnly = false;

        const days = parseInt(config.days);

        if (sourceField === 'von') {
            if (inputVon.value) {
                let start = new Date(inputVon.value);
                let end = new Date(start);
                end.setDate(start.getDate() + days);
                inputBis.value = end.toISOString().split('T')[0];
            }
        } else if (sourceField === 'bis') {
            if (inputBis.value) {
                let end = new Date(inputBis.value);
                let start = new Date(end);
                start.setDate(end.getDate() - days);

                const startStr = start.toISOString().split('T')[0];

                if (startStr < today) {
                    inputVon.value = today;
                    showDateWarning("Der Startzeitpunkt wurde auf heute gesetzt, da Genehmigungen nicht in der Vergangenheit beginnen können.");
                    // Bis neu berechnen basierend auf dem korrigierten "Heute"
                    let newEnd = new Date();
                    newEnd.setDate(newEnd.getDate() + days);
                    inputBis.value = newEnd.toISOString().split('T')[0];
                } else {
                    inputVon.value = startStr;
                }
            }
        }
    }

    // Event-Listener
    selectTpl.addEventListener('change', () => {
        const config = templates[selectTpl.value];
        if (config.days !== 'custom') {
            updateDates('von');
        } else {
            inputBis.readOnly = false;
            inputBis.style.background = '#fff';
        }
    });

    inputVon.addEventListener('change', () => updateDates('von'));
    inputBis.addEventListener('change', () => updateDates('bis'));

    // Initialisierung
    updateDates('von');

    /**
     * Formular-Absendung
     */
    function submitUnifiedForm(actionType) {
        const form = document.getElementById('unifiedToolsForm');
        const reasonField = document.getElementById('u_reason');
        const nameField = document.getElementById('u_name');
        const parzelleField = document.getElementById('u_parzelle');

        [reasonField, nameField, parzelleField].forEach(f => f.setCustomValidity(''));

        if (actionType === 'create_voucher' && !reasonField.value.trim()) {
            reasonField.setCustomValidity('Grund ist für Gutscheine Pflicht.');
            reasonField.reportValidity();
            return;
        }

        if (actionType === 'create_manual' && (!nameField.value.trim() || !parzelleField.value.trim())) {
            alert('Name und Parzelle sind für Sofort-Genehmigungen Pflicht.');
            return;
        }

        const hiddenAction = document.createElement('input');
        hiddenAction.type = 'hidden';
        hiddenAction.name = 'action';
        hiddenAction.value = actionType;
        form.appendChild(hiddenAction);
        form.submit();
    }
</script>
