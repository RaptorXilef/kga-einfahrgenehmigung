<script>
    /**
     * Smart Form Handler
     * Prüft die benötigten Felder dynamisch je nach Button-Klick und
     * benennt die Variablen so um, dass das PHP Backend sie versteht.
     */
function submitUnifiedForm(actionType) {
    const form = document.getElementById('unifiedToolsForm');

        // HTML Elemente holen
    const reasonField = document.getElementById('u_reason');
    const dateField = document.getElementById('u_datum_von');
    const nameField = document.getElementById('u_name');
    const parzelleField = document.getElementById('u_parzelle');
        const kennzeichenField = document.getElementById('u_kennzeichen');

    // Fehler zurücksetzen
    [reasonField, dateField, nameField, parzelleField].forEach(f => f.setCustomValidity(''));

        // 1. Validierung für Gutscheine
    if (actionType === 'create_voucher') {
        if (!reasonField.value.trim()) {
            reasonField.setCustomValidity('Für Gutscheine ist eine interne Bezeichnung/Grund Pflicht.');
            reasonField.reportValidity();
            return;
        }
    }
    // 2. Validierung für direkte Sofort-Genehmigung
    else if (actionType === 'create_manual') {
        if (!dateField.value) {
                dateField.setCustomValidity('Das Startdatum ist für direkte Genehmigungen Pflicht.');
            dateField.reportValidity();
            return;
        }
        if (!nameField.value.trim() || !parzelleField.value.trim()) {
                nameField.setCustomValidity('Name und Parzelle sind für direkte Genehmigungen Pflicht.');
            nameField.reportValidity();
            return;
        }
    }

        // Wenn HTML5 Validierung fehlschlägt, abbrechen
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }

    // SAUBER: Nur noch die Action setzen, KEIN Umbenennen von Feldern mehr!
    const hiddenAction = document.createElement('input');
    hiddenAction.type = 'hidden';
    hiddenAction.name = 'action';
    hiddenAction.value = actionType;
    form.appendChild(hiddenAction);

    form.submit();
}
</script>
