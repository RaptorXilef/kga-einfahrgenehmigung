<script>
    const templates = <?php echo \json_encode($tplMetadata); ?>;
    const inputVon = document.getElementById('u_datum_von');
    const inputBis = document.getElementById('u_datum_bis');
    const selectTpl = document.getElementById('u_template_key');
    const selectTyp = document.getElementById('u_typ');
    const firmaWrapper = document.getElementById('u_firma_wrapper');
    const warningBox = document.getElementById('date-warning');
    const warningText = document.getElementById('date-warning-text');

    // Zweck-Handling
    let isZweckManual = false;
    const zweckSelect = document.getElementById('u_zweck_select');
    const zweckManual = document.getElementById('u_zweck_manual');
    const zweckToggle = document.getElementById('u_zweck_toggle');

    /**
     * Schaltet zwischen Dropdown und manuellem Textfeld für "Zweck" um
     */
    function toggleZweckMode() {
        isZweckManual = !isZweckManual;
        if (isZweckManual) {
            zweckSelect.style.display = 'none';
            zweckManual.style.display = 'block';
            zweckSelect.name = "_zweck_disabled"; // Verhindert Senden des Dropdowns
            zweckManual.name = "zweck";
            zweckToggle.innerText = "📁 Aus Liste";
            zweckManual.focus();
        } else {
            zweckSelect.style.display = 'block';
            zweckManual.style.display = 'none';
            zweckSelect.name = "zweck";
            zweckManual.name = "_zweck_manual_disabled";
            zweckToggle.innerText = "✏️ Manuell";
        }
    }

    function toggleFirmaField() {
        firmaWrapper.style.display = (selectTyp.value === 'lkw') ? 'block' : 'none';
        if (selectTyp.value !== 'lkw') document.getElementById('u_firma').value = '';
    }

    /**
     * Datums-Warnung
     */
    function showDateWarning(msg) {
        if (!msg) {
            warningBox.style.display = 'none';
            return;
        }
        warningText.innerText = msg;
        warningBox.style.display = 'block';
    }

    function getTodayStr() {
        return new Date().toISOString().split('T')[0];
    }

    /**
     * Bi-Direktionale Berechnung
     */
    function handleDateChange(source) {
        const config = templates[selectTpl.value];
        const today = getTodayStr();
        showDateWarning(null);
        if (config.days === 'custom') return;

        // Spezialzeitraum: Keine Automatik, alles frei
        const duration = parseInt(config.days);
        if (source === 'von' && inputVon.value) {
            let d = new Date(inputVon.value);
            d.setDate(d.getDate() + duration);
            inputBis.value = d.toISOString().split('T')[0];
        } else if (source === 'bis' && inputBis.value) {
            let d = new Date(inputBis.value);
            d.setDate(d.getDate() - duration);
            let vonStr = d.toISOString().split('T')[0];
            if (vonStr < today) {
                inputVon.value = today;
                showDateWarning("Hinweis: Startdatum auf heute korrigiert.");
            } else {
                inputVon.value = vonStr;
            }
        }
    }

    // Event-Listener
    selectTpl.addEventListener('change', () => handleDateChange('von'));
    selectTyp.addEventListener('change', toggleFirmaField);
    inputVon.addEventListener('change', () => handleDateChange('von'));
    inputBis.addEventListener('change', () => handleDateChange('bis'));

    // Initialisierung
    handleDateChange('von');
    toggleFirmaField();

    /**
     * Formular-Absendung
     */
    function submitUnifiedForm(actionType) {
        const form = document.getElementById('unifiedToolsForm');
        const reasonField = document.getElementById('u_reason');
        const nameField = document.getElementById('u_name');
        const parzelleField = document.getElementById('u_parzelle');
        if (actionType === 'create_voucher' && !reasonField.value.trim()) {
            alert('Notiz fehlt.');
            return;
        }
        if (actionType === 'create_manual' && (!nameField.value.trim() || !parzelleField.value.trim())) {
            alert('Name/Parzelle fehlt.');
            return;
        }
        const hiddenAction = document.createElement('input');
        hiddenAction.type = 'hidden';
        hiddenAction.name = 'action';
        hiddenAction.value = actionType;
        form.appendChild(hiddenAction);
        form.submit();
    }
</script>
