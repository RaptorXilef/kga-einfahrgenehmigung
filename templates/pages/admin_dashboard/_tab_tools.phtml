<script>
    const templates = <?php echo \json_encode($tplMetadata); ?>;
    const inputVon = document.getElementById('u_datum_von');
    const inputBis = document.getElementById('u_datum_bis');
    const inputParzelle = document.getElementById('u_parzelle');
    const inputKennzeichen = document.getElementById('u_kennzeichen');
    const selectTpl = document.getElementById('u_template_key');
    const selectTyp = document.getElementById('u_typ');
    const inputPrice = document.getElementById('u_manual_price');
    const priceBtnLabel = document.getElementById('price_mode_label');
    const priceBtnIcon = document.getElementById('price_mode_icon');
    const firmaWrapper = document.getElementById('u_firma_wrapper');
    const warningBox = document.getElementById('date-warning');
    const warningText = document.getElementById('date-warning-text');

    // Heute als String/Basis
    const today = new Date();
    const todayStr = today.toISOString().split('T')[0];
    inputVon.min = todayStr; // Verhindert Datum in der Vergangenheit

    /**
     * Automatische Parzellen-Formatierung (0001)
     */
    inputParzelle.addEventListener('blur', (e) => {
        if (e.target.value) {
            e.target.value = e.target.value.toString().padStart(4, '0');
        }
    });

    /**
     * Preis-Modi: 0 = Auto, 1 = Kostenlos, 2 = Manuell
     */
    let currentPriceMode = 0;

    function updatePriceDisplay() {
        const config = templates[selectTpl.value];
        const isCustom = config.days === 'custom';

        if (isCustom && currentPriceMode !== 2) {
            setPriceMode(2);
            return;
        }

        if (currentPriceMode === 0) {
            const price = config.prices[selectTyp.value] || 0;
            inputPrice.value = parseFloat(price).toFixed(2);
            inputPrice.readOnly = true;
            priceBtnLabel.innerText = "Automatisch";
            priceBtnIcon.src = "assets/img/icons/status-active.webp";
        } else if (currentPriceMode === 1) {
            inputPrice.value = "0.00";
            inputPrice.readOnly = true;
            priceBtnLabel.innerText = "Kostenlos";
            priceBtnIcon.src = "assets/img/icons/status-denied.webp";
        } else {
            inputPrice.readOnly = false;
            priceBtnLabel.innerText = "Manuell";
            priceBtnIcon.src = "assets/img/icons/icon-crayon.webp";
        }
    }

    function setPriceMode(mode) {
        currentPriceMode = mode;
        updatePriceDisplay();
    }

    function cyclePriceMode() {
        const config = templates[selectTpl.value];
        if (config.days === 'custom') {
            setPriceMode(currentPriceMode === 1 ? 2 : 1);
        } else {
            setPriceMode((currentPriceMode + 1) % 3);
        }
    }

    /**
     * Bidirektionale Datumslogik
     */
    function handleDateChange(source) {
        const config = templates[selectTpl.value];
        const isCustom = config.days === 'custom';
        const duration = isCustom ? 0 : parseInt(config.days);

        warningBox.style.display = 'none';

        if (!isCustom) {
            // 1. Berechnung des frühestmöglichen BIS-Datums (Heute + Dauer)
            let minBisDate = new Date(today);
            minBisDate.setDate(minBisDate.getDate() + duration);
            const minBisStr = minBisDate.toISOString().split('T')[0];

            // Sperre im Kalender setzen
            inputBis.min = minBisStr;

            if (source === 'bis') {
                // BIS wurde geändert -> Berechne VON (BIS - Dauer)
                // Aber: Wenn der Nutzer versucht, BIS vor das Minimum zu setzen:
                if (inputBis.value < minBisStr) {
                    inputBis.value = minBisStr;
                    warningText.innerText = "Das Datum wurde auf die Mindestdauer der Vorlage korrigiert.";
                    warningBox.style.display = 'block';
                }

                let d = new Date(inputBis.value);
                d.setDate(d.getDate() - duration);
                inputVon.value = d.toISOString().split('T')[0];

            } else {
                // VON oder Template wurde geändert -> Berechne BIS (VON + Dauer)
                // Sicherstellen, dass VON nicht in der Vergangenheit liegt
                if (inputVon.value < todayStr) inputVon.value = todayStr;
                let d = new Date(inputVon.value);
                d.setDate(d.getDate() + duration);
                inputBis.value = d.toISOString().split('T')[0];
            }
        } else {
            // Logik für Spezialzeitraum (Custom)
            inputBis.min = inputVon.value;
            if (inputBis.value < inputVon.value) inputBis.value = inputVon.value;
        }
        updatePriceDisplay();
    }

    /**
     * Intelligente Kennzeichen-Formatierung  mit Manual Override (inkl. E- und H-Unterstützung)
     */
    inputKennzeichen.addEventListener('blur', (e) => {
        // Falls im Formular vorhanden, Check auf Gutschein-Lock
        if (typeof isVoucherActive !== 'undefined' && isVoucherActive) return;

        let val = e.target.value.toUpperCase().trim();
        if (val.length <= 3) return;

        // Wenn Nutzer ein Minus tippt -> Nur Buchstaben/Zahlen-Lücke fixen
        if (val.includes('-')) {
            e.target.value = val.replace(/([A-Z])([0-9])/, '$1 $2');
            return;
        }

        // Automatik-Modus ohne manuellen Bindestrich
        let clean = val.replace(/[^A-Z0-9]/g, '');

        // RegEx erweitert um [EH]? am Ende
        const pattern4 = /^([A-Z]{2})([A-Z]{2})([0-9]{1,4}[EH]?)$/;
        const berlinPattern = /^(B)([A-Z]{1,2})([0-9]{1,4}[EH]?)$/;
        const complexPattern = /^([A-Z]{1,3})([A-Z]{1,2})([0-9]{1,4}[EH]?)$/;
        const fallbackPattern = /^([A-Z]{1,3})([0-9]{1,4}[EH]?)$/;

        if (pattern4.test(clean)) {
            e.target.value = clean.replace(pattern4, '$1-$2 $3');
        } else if (berlinPattern.test(clean)) {
            e.target.value = clean.replace(berlinPattern, '$1-$2 $3');
        } else if (complexPattern.test(clean)) {
            e.target.value = clean.replace(complexPattern, '$1-$2 $3');
        } else if (fallbackPattern.test(clean)) {
            e.target.value = clean.replace(fallbackPattern, '$1 $2');
        }
    });

    /**
     * Firma ein/ausblenden
     */
    function toggleFirmaField() {
        const isLkw = selectTyp.value === 'lkw';
        firmaWrapper.classList.toggle('u-hidden', !isLkw);
        if (!isLkw) document.getElementById('u_firma').value = '';
    }

    function toggleZweckMode() {
        const select = document.getElementById('u_zweck_select');
        const manual = document.getElementById('u_zweck_manual');
        const toggle = document.getElementById('u_zweck_toggle');

        if (select.style.display === 'none') {
        // Modus: Liste anzeigen
            select.style.display = 'block';
            manual.style.display = 'none';
            select.name = "zweck";
            manual.name = "_unused";

        // Icon: Crayon/Stift für "Wechsel zu Manuell"
            toggle.innerHTML = '<img src="assets/img/icons/icon-crayon.webp" class="c-icon" alt=""> Manuell';
        } else {
        // Modus: Manuelle Eingabe anzeigen
            select.style.display = 'none';
            manual.style.display = 'block';
            select.name = "_unused";
            manual.name = "zweck";

        // Icon: Folder/Ordner für "Wechsel zu Liste"
            toggle.innerHTML = '<img src="assets/img/icons/icon-open-file-folder.webp" class="c-icon" alt=""> Liste';

            manual.focus();
        }
    }

    function submitUnifiedForm(actionType) {
        const form = document.getElementById('unifiedToolsForm');
        if (actionType === 'create_manual' && (!document.getElementById('u_name').value || !inputParzelle.value)) {
            alert('Bitte Name und Parzelle ausfüllen.');
            return;
        }
        const hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'action';
        hidden.value = actionType;
        form.appendChild(hidden);
        form.submit();
    }

    selectTpl.addEventListener('change', () => handleDateChange('template'));
    inputVon.addEventListener('change', () => handleDateChange('von'));
    inputBis.addEventListener('change', () => handleDateChange('bis'));
    selectTyp.addEventListener('change', toggleFirmaField);

    // Initialisierung beim Laden
    handleDateChange('init');
    toggleFirmaField();
</script>
