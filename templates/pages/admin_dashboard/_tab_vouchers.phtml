    <script>
    // --- NEU: JS für das QR-Modal ---
    function showVoucherQr(code, url) {
        const modal = document.getElementById('qrModal');
        const img = document.getElementById('qrModalImg');
        const loader = document.getElementById('qrModalLoader');

        document.getElementById('qrModalCode').innerText = code;

        // UI Reset
        img.style.display = 'none';
        loader.style.display = 'block';
        modal.style.display = 'flex';

        // API Abruf erst HIER beim Klick
        const encodedUrl = encodeURIComponent(url);
        const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=250x250&margin=10&data=${encodedUrl}`;

        img.onload = () => {
            loader.style.display = 'none';
            img.style.display = 'block';
        };
        img.src = qrUrl;
    }

    function closeVoucherQr() {
        document.getElementById('qrModal').style.display = 'none';
        document.getElementById('qrModalImg').src = ''; // src leeren, damit beim nächsten Mal der Lader kommt
    }

    // Klick außerhalb des Popups schließt es auch
    document.getElementById('qrModal').addEventListener('click', function(e) {
        if (e.target === this) closeVoucherQr();
    });

    // --- Bestehende Copy-Logik ---
    function copyVoucherLink(url, element) {
        // Funktion für das visuelle Feedback
        const successAction = () => {
            const originalText = element.innerText;
            element.innerText = 'Kopiert! ✓';
            element.style.color = 'var(--success-color)';

            if (typeof showToast === "function") {
                showToast("Gutschein-Link kopiert!");
            }

            setTimeout(() => {
                element.innerText = originalText;
                element.style.color = 'var(--primary-color)';
            }, 2000);
        };

        // 1. Versuch: Moderne Clipboard API
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(url)
                .then(successAction)
                .catch(err => {
                    console.error('Fehler beim Kopieren:', err);
                    fallbackCopyText(url, successAction);
                });
        } else {
            // 2. Versuch: Fallback für HTTP / .local Domains
            fallbackCopyText(url, successAction);
        }
    }

    /**
     * Fallback-Methode für nicht-HTTPS Umgebungen
     */
    function fallbackCopyText(text, callback) {
        const textArea = document.createElement("textarea");
        textArea.value = text;

        // Sicherstellen, dass das Feld nicht sichtbar ist
        textArea.style.position = "fixed";
        textArea.style.left = "-9999px";
        textArea.style.top = "0";

        document.body.appendChild(textArea);
        textArea.focus();
        textArea.select();

        try {
            const successful = document.execCommand('copy');
            if (successful) {
                callback();
            }
        } catch (err) {
            console.error('Fallback Kopieren fehlgeschlagen', err);
        }

        document.body.removeChild(textArea);
    }

    /**
     * Toast-Benachrichtigung anzeigen
     */
    function showToast(message) {
        const existingToast = document.querySelector('.c-toast');
        if (existingToast) existingToast.remove();

        const toast = document.createElement('div');
        toast.className = 'c-toast';
        toast.innerHTML =
            `<img src="<?php echo $settings['base_url']; ?>assets/img/icons/status-success.webp" class="c-icon" style="width:16px"> ${message}`;
        document.body.appendChild(toast);

        setTimeout(() => {
            toast.classList.add('c-toast--hide');
            setTimeout(() => toast.remove(), 500);
        }, 3000);
    }

    </script>
