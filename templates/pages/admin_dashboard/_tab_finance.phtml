                <?php if ($totalPages > 1) {
                    $queryParams = $_GET;
                    unset($queryParams['page']);
                    $baseUrlStr = '?' . \http_build_query($queryParams) . '&page=';

                    // --- Smarte Paginierungs-Logik ---
                    $adjacents   = 2; // Zeige 2 Seiten links und rechts der aktuellen
                    $pagesToShow = [];
                    if ($totalPages <= (1 + ($adjacents * 2) + 2)) {
                        for ($i = 1; $i <= $totalPages; ++$i) {
                            $pagesToShow[] = $i;
                        }
                    } else {
                        if ($page <= $adjacents + 2) {
                            for ($i = 1; $i <= 1 + ($adjacents * 2); ++$i) {
                                $pagesToShow[] = $i;
                            }
                            $pagesToShow[] = '...';
                            $pagesToShow[] = $totalPages;
                        } elseif ($totalPages - $page <= $adjacents + 1) {
                            $pagesToShow[] = 1;
                            $pagesToShow[] = '...';
                            for ($i = $totalPages - ($adjacents * 2); $i <= $totalPages; ++$i) {
                                $pagesToShow[] = $i;
                            }
                        } else {
                            $pagesToShow[] = 1;
                            $pagesToShow[] = '...';
                            for ($i = $page - $adjacents; $i <= $page + $adjacents; ++$i) {
                                $pagesToShow[] = $i;
                            }
                            $pagesToShow[] = '...';
                            $pagesToShow[] = $totalPages;
                        }
                    }
                    ?>
                    <div class="u-flex u-justify-between u-align-center u-padding-around-m"
                         style="background: var(--bg-light); border-top: 1px solid var(--border-color); flex-wrap: wrap; gap: 10px;">
