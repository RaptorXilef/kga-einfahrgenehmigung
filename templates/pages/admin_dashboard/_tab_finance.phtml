    <script>
    function updateBulkPayButton() {
        const checkboxes = document.querySelectorAll('.js-bulk-pay-cb:checked');
        const btn = document.getElementById('bulkPayBtn');
        const countSpan = document.getElementById('bulkPayCount');
        if (btn && countSpan) {
            countSpan.innerText = checkboxes.length;
            btn.style.display = checkboxes.length > 0 ? 'inline-flex' : 'none';
        }
    }

    function toggleAllBulkPay(source) {
        document.querySelectorAll('.js-bulk-pay-cb').forEach(cb => {
            cb.checked = source.checked;
        });
        updateBulkPayButton();
    }

    </script>
