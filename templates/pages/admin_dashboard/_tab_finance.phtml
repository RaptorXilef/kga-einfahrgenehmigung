                                <?php } else { ?>
                                    <a href="<?php echo $baseUrlStr . $p; ?>"
                                       class="c-button c-button--secondary"
                                       style="padding: 6px 12px; font-size: 0.85rem;">
                                        <?php echo $p; ?>
                                    </a>
                            <?php }
                                } ?>

