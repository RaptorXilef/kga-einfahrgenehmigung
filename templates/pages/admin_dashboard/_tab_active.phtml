<?php

/**
 * Partial: Dashboard Tab Content - Active Permits
 *
 * Path: templates/pages/admin_dashboard/_tab_active.phtml
 *
 * @var array<string, array<\App\Core\Entity\Permit>> $groups
 * @var \App\Core\Service\PermitService               $permitService
 * @var int                                           $adminLevel
 */
?>
<div class="c-tab-content-container">
    <section class="c-card">
        <header class="c-card__header">
            <h3 class="u-margin-none"><img src="assets/img/icons/status-active.webp" class="c-icon" alt=""><!-- 🟢 --> Aktive Genehmigungen</h3>
            <p class="u-text-muted">Alle aktuell gültigen Einfahrtsberechtigungen im System.</p>
        </header>

        <div class="c-card__body u-padding-none">
            <table class="c-table">
                <thead>
                    <tr>
                        <th>Kennung / Name</th>
                        <th>Status</th>
                        <?php if ($adminLevel < 3) { ?>
                            <th>Betrag</th>
                        <?php } ?>
                        <th class="u-text-right">Aktion</th>
                    </tr>
                </thead>
                <tbody>
                    <?php if (empty($groups['active'])) { ?>
                        <tr>
                            <td colspan="<?php echo ($adminLevel < 3) ? 4 : 3; ?>" class="u-text-center u-text-muted u-padding-around-l">
                                Aktuell keine aktiven Genehmigungen vorhanden.
                            </td>
                        </tr>
                    <?php } else { ?>
                        <?php foreach ($groups['active'] as $permit) { ?>
                            <?php $overdueLevel = $permitService->getOverdueLevel($permit); ?>

                            <tr class="<?php echo $permit->status->isSuspended ? 'u-bg-suspended' : ''; ?>">
                                <td>
                                    <code><?php echo \htmlspecialchars($permit->code); ?></code><br>
                                    <small>
                                        <strong><?php echo \htmlspecialchars($permit->owner->name); ?></strong>
                                        (Parz: <?php echo \htmlspecialchars($permit->owner->parzelle); ?>)
                                    </small>
                                </td>

                                <td>
                                    <?php if ($permit->status->isSuspended) { ?>
                                        <span class="c-badge c-badge--danger"><img src="assets/img/icons/status-denied.webp" class="c-icon" alt=""><!-- ⛔ --> GESPERRT</span>
                                    <?php } else { ?>
                                        <span class="c-badge c-badge--<?php echo $permit->status->current === 'bezahlt' ? 'success' : 'warning'; ?>">
                                            <?php echo \strtoupper($permit->status->current); ?>
                                        </span>

                                        <?php if ($overdueLevel === 1) { ?>
                                            <span class="c-badge" style="background: #e67e22; color: white;">ÜBERFÄLLIG</span>
                                        <?php } elseif ($overdueLevel === 2) { ?>
                                            <span class="c-badge c-badge--danger">🚨 ALARM</span>
                                        <?php } ?>
                                    <?php } ?>
                                </td>

                                <?php if ($adminLevel < 3) { ?>
                                    <td><?php echo \number_format($permit->validity->preisSnapshot, 2, ',', '.'); ?> €</td>
                                <?php } ?>

                                <td class="u-text-right">
                                    <div class="u-flex u-gap-xs u-justify-end">

                                        <!-- DRUCKVORSCHAU -->
                                        <a href="?action=print&code=<?php echo $permit->code; ?>"
                                            class="c-button c-button--secondary" title="Druckvorschau">
                                            <img src="assets/img/icons/action-print.webp" class="c-icon" alt="Drucken"><!-- 🖨️ -->
                                        </a>

                                        <?php if ($permit->status->isSuspended) { ?>
                                            <!-- ENTSPERREN -->
                                            <form method="POST" style="margin:0;">
                                                <input type="hidden" name="action" value="unsuspend_permit">
                                                <input type="hidden" name="code" value="<?php echo $permit->code; ?>">
                                                <button type="submit" class="c-button c-button--success" title="Entsperren">
                                                    <img src="assets/img/icons/action-unlock.webp" class="c-icon" alt="Entsperren"><!-- 🔓 -->
                                                </button>
                                            </form>
                                        <?php } else { ?>
                                            <?php if ($permit->status->current !== 'bezahlt' && $adminLevel <= 1) { ?>
                                                <!-- MANUELL BEZAHLT -->
                                                <form method="POST" style="margin:0;">
                                                    <input type="hidden" name="action" value="mark_as_paid">
                                                    <input type="hidden" name="code" value="<?php echo $permit->code; ?>">
                                                    <button type="submit" class="c-button c-button--success" title="Zahlung bestätigen">
                                                        <img src="assets/img/icons/status-success.webp" class="c-icon" alt="Zahlung erhalten"><!-- ✅ -->
                                                    </button>
                                                </form>
                                            <?php } ?>

                                            <!-- SPERREN -->
                                            <button class="c-button c-button--danger js-suspend-btn"
                                                data-code="<?php echo $permit->code; ?>"
                                                title="Sperren">
                                                <img src="assets/img/icons/status-denied.webp" class="c-icon" alt="Sperren"><!-- ⛔ -->
                                            </button>

                                            <form id="form_suspend_<?php echo $permit->code; ?>" method="POST" style="display:none;">
                                                <input type="hidden" name="action" value="suspend_permit">
                                                <input type="hidden" name="code" value="<?php echo $permit->code; ?>">
                                                <input type="hidden" name="reason" id="reason_suspend_<?php echo $permit->code; ?>">
                                            </form>
                                        <?php } ?>

                                        <!-- PRÜFSEITE ÖFFNEN -->
                                        <a href="check.php?code=<?php echo $permit->code; ?>"
                                            target="_blank"
                                            class="c-button c-button--secondary" title="Prüfseite öffnen">
                                            <img src="assets/img/icons/action-view.webp" class="c-icon" alt="Prüfen"><!-- 👁️ -->
                                        </a>

                                    </div>
                                </td>
                            </tr>
                        <?php } ?>
                    <?php } ?>
                </tbody>
            </table>
        </div>
    </section>
</div>
