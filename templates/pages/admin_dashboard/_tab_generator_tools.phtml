    <script>
    const templates = <?php echo \json_encode($tplMetadata); ?>;
    const inputVon = document.getElementById('u_datum_von');
    const inputBis = document.getElementById('u_datum_bis');
    const inputParzelle = document.getElementById('u_parzelle');
    const inputKennzeichen = document.getElementById('u_kennzeichen');
    const selectTpl = document.getElementById('u_template_key');
    const selectTyp = document.getElementById('u_typ');
    const inputPrice = document.getElementById('u_manual_price');
    const priceBtnLabel = document.getElementById('price_mode_label');
    const priceBtnIcon = document.getElementById('price_mode_icon');

    const today = new window.Date(); // TODO wenn in eigener JS Datei das "window." entfernen
    const todayStr = today.toISOString().split('T')[0];
    inputVon.min = todayStr;

    let currentPriceMode = 0; // 0=Auto, 1=Free, 2=Manual
    let generatorMode = null;

    function setGeneratorMode(mode) {
        generatorMode = mode;

        // CSS Korrektur: Aktive Klasse setzen/entfernen
        document.getElementById('btn_mode_manual').classList.toggle('c-gen-mode-card--active', mode === 'manual');
        document.getElementById('btn_mode_voucher').classList.toggle('c-gen-mode-card--active', mode === 'voucher');

        // UI Umschaltung
        document.getElementById('area_manual_issue').style.display = (mode === 'manual') ? 'block' : 'none';
        document.getElementById('area_voucher_config').style.display = (mode === 'voucher') ? 'block' : 'none';
        document.getElementById('area_common_note').style.display = 'block';

        document.getElementById('action_grid').style.display = 'grid';
        document.getElementById('card_submit_manual').style.display = (mode === 'manual') ? 'flex' : 'none';
        document.getElementById('card_submit_voucher').style.display = (mode === 'voucher') ? 'flex' : 'none';

        if (mode === 'manual') updatePriceDisplay();
        else updateVoucherUI();
    }

    function updatePriceDisplay() {
        const config = templates[selectTpl.value];
        if (config.days === 'custom' && currentPriceMode === 0) {
            setPriceMode(2);
            return;
        }

        if (currentPriceMode === 0) {
            const price = config.prices[selectTyp.value] || 0;
            inputPrice.value = parseFloat(price).toFixed(2);
            inputPrice.readOnly = true;
            priceBtnLabel.innerText = "Automatisch";
            priceBtnIcon.src = window.KGA_CONFIG.baseUrl + "assets/img/icons/icon-money-bag.webp";
        } else if (currentPriceMode === 1) {
            inputPrice.value = "0.00";
            inputPrice.readOnly = true;
            priceBtnLabel.innerText = "Kostenlos";
            priceBtnIcon.src = window.KGA_CONFIG.baseUrl + "assets/img/icons/icon-free.webp";
        } else {
            inputPrice.readOnly = false;
            priceBtnLabel.innerText = "Manuell";
            priceBtnIcon.src = window.KGA_CONFIG.baseUrl + "assets/img/icons/icon-dollar-sign.webp";
        }
    }

    function setPriceMode(mode) {
        currentPriceMode = mode;
        updatePriceDisplay();
    }

    function cyclePriceMode() {
        const config = templates[selectTpl.value];

        // Sonderfall für Custom-Vorlagen (erlauben kein "Automatisch")
        if (config.days === 'custom') {
            // Wechselt nur zwischen Manuell (2) und Kostenlos (1)
            setPriceMode(currentPriceMode === 2 ? 1 : 2);
        } else {
            // Neue Reihenfolge für Standard-Vorlagen: 0 (Auto) -> 2 (Manuell) -> 1 (Kostenlos)
            if (currentPriceMode === 0) setPriceMode(2); // Von Auto zu Manuell
            else if (currentPriceMode === 2) setPriceMode(1); // Von Manuell zu Kostenlos
            else setPriceMode(0); // Von Kostenlos zurück zu Auto
        }
    }

    /**
     * Fix für Mehrfach-Nutzung und Senioren-Labels
     */
    function updateVoucherUI() {
        const type = document.getElementById('v_type').value;
        const multi = document.getElementById('v_multi').checked;
        const valWrapper = document.getElementById('v_value_wrapper');
        const valLabel = document.getElementById('v_value_label');
        const valHint = document.getElementById('v_value_hint');
        const maxWrapper = document.getElementById('v_max_wrapper');

        // Rabatt-Felder
        valWrapper.style.display = (type === 'free') ? 'none' : 'block';
        if (type !== 'free') {
            if (type === 'percent') {
                valLabel.innerText = 'Abzug (%)';
                valHint.innerText = 'Z.B. 20 für 20% Rabatt.';
            } else {
                valLabel.innerText = 'Festpreis (€)';
                valHint.innerText = 'Genauer Zahlbetrag.';
            }
        }

        // Fix: Das Feld für die Anzahl taucht jetzt korrekt auf
        maxWrapper.style.display = multi ? 'inline-block' : 'none';
    }

    // AJAX Call für die Live-Darstellung der Feiertage (Korrigeriert auf JSON-POST)
    async function fetchDateInfo() {
        if (!inputVon || !inputBis) return;
        try {
            const res = await fetch(window.KGA_CONFIG.baseUrl + 'api/get_date_info.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': window.KGA_CONFIG.csrfToken
                },
                body: JSON.stringify({
                    von: inputVon.value,
                    bis: inputBis.value
                })
            });
            const data = await res.json();
            const container = document.getElementById('dynamic-date-info');
            const openingEl = document.getElementById('dynamic-opening-hours');
            const holidayEl = document.getElementById('dynamic-holiday-notice');

            if (data.success) {
                openingEl.innerHTML = data.openingHours;
                if (data.holidayNotice) {
                    holidayEl.innerHTML = data.holidayNotice;
                    holidayEl.style.display = 'block';
                } else {
                    holidayEl.style.display = 'none';
                }
                container.style.display = 'block';
            }
        } catch (e) {
            console.error('Fehler beim Laden der Datums-Infos', e);
        }
    }

    // --- BEIBEHALTENE LOGIKEN (Formatierung & Datum) ---
    function handleDateChange(source) {
        const config = templates[selectTpl.value];
        const isCustom = config.days === 'custom';
        const duration = isCustom ? 0 : parseInt(config.days);
        const durationOffset = Math.max(0, duration - 1); // FIX: -1 Tag

        if (!isCustom) {
            let minBisDate = new window.Date(today); // TODO wenn in eigener JS Datei das "window." entfernen
            minBisDate.setDate(minBisDate.getDate() + durationOffset);
            inputBis.min = minBisDate.toISOString().split('T')[0];

            if (source === 'bis') {
                let d = new window.Date(inputBis.value); // TODO wenn in eigener JS Datei das "window." entfernen
                d.setDate(d.getDate() - durationOffset);
                inputVon.value = d.toISOString().split('T')[0];
            } else {
                if (inputVon.value < todayStr) inputVon.value = todayStr;
                let d = new window.Date(inputVon.value); // TODO wenn in eigener JS Datei das "window." entfernen
                d.setDate(d.getDate() + durationOffset);
                inputBis.value = d.toISOString().split('T')[0];
            }
        } else {
            // Logik für Spezialzeitraum (Custom)
            inputBis.min = inputVon.value;
        }
        if (generatorMode === 'manual') updatePriceDisplay();

        fetchDateInfo();
    }

    /**
     * Automatische Parzellen-Formatierung (0001)
     */
    inputParzelle.addEventListener('blur', (e) => {
        if (e.target.value) e.target.value = e.target.value.toString().padStart(4, '0');
    });

    /**
     * Intelligente Kennzeichen-Formatierung  mit Manual Override (inkl. E- und H-Unterstützung)
     */
    inputKennzeichen.addEventListener('blur', (e) => {
        let val = e.target.value.toUpperCase().trim();
        if (val.length <= 3) return;

        // Wenn Nutzer ein Minus tippt -> Nur Buchstaben/Zahlen-Lücke fixen
        if (val.includes('-')) {
            e.target.value = val.replace(/([A-Z])([0-9])/, '$1 $2');
            return;
        }

        // Automatik-Modus ohne manuellen Bindestrich
        let clean = val.replace(/[^A-Z0-9]/g, '');

        // RegEx erweitert um [EH]? am Ende
        const pattern4 = /^([A-Z]{2})([A-Z]{2})([0-9]{1,4}[EH]?)$/;
        const berlinPattern = /^(B)([A-Z]{1,2})([0-9]{1,4}[EH]?)$/;
        const complexPattern = /^([A-Z]{1,3})([A-Z]{1,2})([0-9]{1,4}[EH]?)$/;
        const fallbackPattern = /^([A-Z]{1,3})([0-9]{1,4}[EH]?)$/;

        if (pattern4.test(clean)) e.target.value = clean.replace(pattern4, '$1-$2 $3');
        else if (berlinPattern.test(clean)) e.target.value = clean.replace(berlinPattern, '$1-$2 $3');
        else if (complexPattern.test(clean)) e.target.value = clean.replace(complexPattern, '$1-$2 $3');
        else if (fallbackPattern.test(clean)) e.target.value = clean.replace(fallbackPattern, '$1 $2');
    });

    /**
     * Firma ein/ausblenden
     */
    function toggleFirmaField() {
        const type = selectTyp.value;
        // Zugriff auf die via admin_dashboard.phtml injizierte Config
        const vCfg = window.KGA_CONFIG.vehicleConfig[type] || {
            show_company: false
        };
        document.getElementById('u_firma_wrapper').classList.toggle('u-hidden', !vCfg.show_company);
    }

    function toggleZweckMode() {
        const select = document.getElementById('u_zweck_select');
        const manual = document.getElementById('u_zweck_manual');
        const toggle = document.getElementById('u_zweck_toggle');

        if (select.style.display === 'none') {
            // Modus: Liste anzeigen
            select.style.display = 'block';
            manual.style.display = 'none';
            select.name = "zweck";
            manual.name = "_unused";

            // Icon: Crayon/Stift für "Wechsel zu Manuell"
            toggle.innerHTML =
                `<img src="${window.KGA_CONFIG.baseUrl}assets/img/icons/icon-crayon.webp" class="c-icon" alt=""> Manuell`;
        } else {
            // Modus: Manuelle Eingabe anzeigen
            select.style.display = 'none';
            manual.style.display = 'block';
            select.name = "_unused";
            manual.name = "zweck";

            // Icon: Folder/Ordner für "Wechsel zu Liste"
            toggle.innerHTML =
                `<img src="${window.KGA_CONFIG.baseUrl}assets/img/icons/icon-open-file-folder.webp" class="c-icon" alt=""> Liste`;

            manual.focus();
        }
    }

    function submitUnifiedForm(actionType) {
        const form = document.getElementById('unifiedToolsForm');
        if (actionType === 'create_manual' && (!document.getElementById('u_name').value || !inputParzelle.value)) {
            alert('Bitte Name und Parzelle ausfüllen.');
            return;
        }
        const hidden = document.createElement('input');
        hidden.type = 'hidden';
        hidden.name = 'action';
        hidden.value = actionType;
        form.appendChild(hidden);
        form.submit();
    }

    selectTpl.addEventListener('change', () => handleDateChange('template'));
    inputVon.addEventListener('change', () => handleDateChange('von'));
    inputBis.addEventListener('change', () => handleDateChange('bis'));
    selectTyp.addEventListener('change', toggleFirmaField);

    // Initialisierung beim Laden
    handleDateChange('init');
    toggleFirmaField();

    // Unsichtbarer Heartbeat: Hält die PHP-Session und den CSRF-Token am Leben,
    // während der Pächter sich Zeit beim Ausfüllen lässt. (Alle 5 Minuten)
    setInterval(() => {
        fetch(window.location.pathname + '?ping=' + Date.now(), {
                method: 'HEAD',
                cache: 'no-store',
                credentials: 'same-origin' // FIX: Sendet den Session-Cookie mit!
            })
            .catch(() => console.debug('Session Ping fehlgeschlagen'));
    }, 5 * 60 * 1000);

    </script>
<?php } ?>
