    <?php /* <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> */ ?>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const ctx = document.getElementById('yearlyStatsChart');
        if (!ctx) return;

        // --- Daten aus PHP generieren ---

        // Paket 1: Jahresdaten (wie bisher)
        const yearLabels = <?php echo \json_encode(\array_reverse(\array_keys($yearlyStats))); ?>;
        const yearRevenue = <?php echo \json_encode(\array_reverse(\array_map(fn ($d) => $d['paid'] + $d['unpaid'], $yearlyStats))); ?>;
        const yearCounts = <?php echo \json_encode(\array_reverse(\array_map(fn ($d) => $d['count'], $yearlyStats))); ?>;

        // Paket 2: Monatsdaten (NEU)
        const monthLabels = <?php echo \json_encode(\array_values($monthLabels)); ?>;
        const monthRevenue = <?php echo \json_encode(\array_values($monthRevenue)); ?>;
        const monthCounts = <?php echo \json_encode(\array_values($monthCounts)); ?>;

        // Chart initialisieren (Standardmäßig Monatlich)
        let currentChart = new window.Chart(ctx, {
            type: 'bar',
            data: {
                labels: monthLabels,
                datasets: [{
                        label: 'Umsatz Soll (€)',
                        data: monthRevenue,
                        backgroundColor: 'rgba(52, 152, 219, 0.6)',
                        borderColor: '#3498db',
                        borderWidth: 2,
                        borderRadius: 5,
                        yAxisID: 'y'
                    },
                    {
                        label: 'Anzahl Genehmigungen',
                        data: monthCounts,
                        borderColor: '#6366f1',
                        backgroundColor: '#6366f1',
                        borderWidth: 3,
                        type: 'line',
                        tension: 0.3,
                        pointRadius: 5,
                        yAxisID: 'y1'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                if (context.datasetIndex === 0) {
                                    label += new window.Intl.NumberFormat('de-DE', {
                                        style: 'currency',
                                        currency: 'EUR'
                                    }).format(context.raw);
                                } else {
                                    label += context.raw + ' Stück';
                                }
                                return label;
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        type: 'linear',
                        position: 'left',
                        grid: {
                            color: '#f1f5f9'
                        },
                        title: {
                            display: true,
                            text: 'Euro (€)',
                            font: {
                                weight: 'bold'
                            }
                        }
                    },
                    y1: {
                        type: 'linear',
                        position: 'right',
                        grid: {
                            drawOnChartArea: false
                        },
                        title: {
                            display: true,
                            text: 'Menge',
                            font: {
                                weight: 'bold'
                            }
                        }
                    }
                }
            }
        });

        // --- Toggle Logik (Monatlich / Jährlich) ---
        const btnMonth = document.getElementById('chartToggleMonth');
        const btnYear = document.getElementById('chartToggleYear');

        btnMonth.addEventListener('click', (e) => {
            e.preventDefault();
            // UI anpassen
            btnMonth.classList.replace('c-button--secondary', 'c-button--primary');
            btnYear.classList.replace('c-button--primary', 'c-button--secondary');

            // Chart-Daten austauschen & updaten
            currentChart.data.labels = monthLabels;
            currentChart.data.datasets[0].data = monthRevenue;
            currentChart.data.datasets[1].data = monthCounts;
            currentChart.update();
        });

        btnYear.addEventListener('click', (e) => {
            e.preventDefault();
            // UI anpassen
            btnYear.classList.replace('c-button--secondary', 'c-button--primary');
            btnMonth.classList.replace('c-button--primary', 'c-button--secondary');

            // Chart-Daten austauschen & updaten
            currentChart.data.labels = yearLabels;
            currentChart.data.datasets[0].data = yearRevenue;
            currentChart.data.datasets[1].data = yearCounts;
            currentChart.update();
        });
    });

    </script>
