/**
 * Partial: Dashboard Tab - Mail Logs
 *
 * Path: templates/pages/admin_dashboard/_tab_logs.phtml
 *
 * @var array                             $mailLogs
 * @var \App\Infrastructure\Config\Config $config
 */

// Limit aus der Config holen
$displayLimit = (int) $config->get('mail_log_display_limit', 50);
?>
<div class="c-tab-content-container">
    <section class="c-card">
        <header class="c-card__header">
            <h3 class="u-margin-none"><img src="assets/img/icons/nav-logs.webp" class="c-icon" alt=""> E-Mail Versand-Log</h3>
            <p class="u-text-muted">Die letzten <?php echo $displayLimit; ?> versendeten System-Nachrichten.</p>
        </header>
        <div class="u-padding-none">
            <table class="c-table">
                <thead>
                    <tr>
                        <th style="width: 150px;">Zeitpunkt</th>
                        <th>Empfänger</th>
                        <th>Betreff & Vorlage</th>
                        <th class="u-text-right">Status</th>
                    </tr>
                </thead>
                <tbody>
                    <?php if (empty($mailLogs)) { ?>
                        <tr>
                            <td colspan="4" class="u-text-center u-padding-around-l">Keine Mail-Logs gefunden.</td>
                        </tr>
                    <?php } else { ?>
                        <?php
                        // Hier nutzen wir das dynamische Limit für den Array-Schnitt
                        foreach (\array_slice($mailLogs, 0, $displayLimit) as $log) { ?>
                            <tr>
                                <td>
                                    <span style="font-size: 0.85rem; color: var(--text-muted);">
                                        <?php echo \date('d.m.Y', \strtotime($log['timestamp'])); ?><br>
                                        <strong><?php echo \date('H:i', \strtotime($log['timestamp'])); ?> Uhr</strong>
                                    </span>
                                </td>
                                <td>
                                    <span class="u-font-bold"><?php echo \htmlspecialchars($log['recipient']); ?></span>
                                </td>
                                <td>
                                    <strong><?php echo \htmlspecialchars($log['subject']); ?></strong><br>
                                    <small class="u-text-muted">Template: <code><?php echo $log['template']; ?></code></small>
                                </td>
                                <td class="u-text-right">
                                    <span class="c-badge c-badge--<?php echo ($log['status'] === 'Erfolg') ? 'success' : 'danger'; ?>">
                                        <?php echo ($log['status'] === 'Erfolg') ?
                                            '<img src="assets/img/icons/status-success.webp" class="c-icon" alt=""><!-- ✅ --> Gesendet' :
                                            '<img src="assets/img/icons/status-invalid.webp" class="c-icon" alt=""><!-- ❌ --> Fehler'; ?>
                                    </span>
                                </td>
                            </tr>
                        <?php } ?>
                    <?php } ?>
                </tbody>
            </table>
        </div>
    </section>
</div>
