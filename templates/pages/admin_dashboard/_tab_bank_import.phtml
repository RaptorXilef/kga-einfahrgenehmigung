<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. Drag & Drop Funktionalität absichern
    const zone = document.getElementById('csvDropzone');
    const input = document.getElementById('bankCsvInput');
    if (zone && input) {
        zone.addEventListener('click', () => input.click());
        zone.addEventListener('dragover', (e) => {
            e.preventDefault();
            zone.style.borderColor = 'var(--primary-color)';
        });
        zone.addEventListener('dragleave', () => {
            zone.style.borderColor = 'var(--border-color)';
        });
        zone.addEventListener('drop', (e) => {
            e.preventDefault();
            if (e.dataTransfer.files.length > 0) {
                input.files = e.dataTransfer.files;
                document.getElementById('bankCsvForm').submit();
            }
        });
    }

    // 2. Dynamische Live-Vorschau der selektierten Spaltenwerte
    <?php if ($rowPreviewExist) { ?>
        const rowData = <?php echo \json_encode($bank_row_preview, \JSON_UNESCAPED_UNICODE); ?>;

        function updatePreview(selectElement) {
            const selectedIndex = parseInt(selectElement.value);
            const targetId = selectElement.getAttribute('data-preview-target');
            const targetDisplay = document.getElementById(targetId);

            if (targetDisplay) {
                const value = (rowData[selectedIndex] !== undefined && rowData[selectedIndex] !== '') ?
                    rowData[selectedIndex] :
                    '[LEER]';
                targetDisplay.innerText = value;
            }
        }

        document.querySelectorAll('.js-bank-selector').forEach(select => {
            select.addEventListener('change', (e) => updatePreview(e.target));
            updatePreview(select); // Initiale Vorschau laden
        });
    <?php } ?>
});

</script>
