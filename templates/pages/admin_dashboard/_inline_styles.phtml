    border-color: #a7f3d0;
}

.c-alert--info {
    background: var(--primary-soft);
    color: #1e40af;
    border-color: #bfdbfe;
}

/* Code-Hervorhebung innerhalb der Nachricht */
.c-alert strong {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    background: rgba(255, 255, 255, 0.5);
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.5px;
    font-size: 1.05rem;
}

/* Universal-Klasse für Icons */
.c-icon {
    display: inline-block;
    width: 1em;
    /* Passt sich der Textgröße an */
    height: 1em;
    vertical-align: middle;
    margin-top: -2px;
    /* Optische Korrektur */
    object-fit: contain;
}

/* Die Icon-Größe innerhalb der Buttons */
.c-button .c-icon {
    width: 1.2em;
    height: 1.2em;
    margin: 0;
    /* Kein Margin nötig, da der Button zentriert */
}

/* Icons in der Navigation */
.c-tabs__btn .c-icon {
    width: 1.4em;
