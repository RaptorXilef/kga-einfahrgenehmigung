/* Animation für die Auto-Aktivierung */




/* --- UI MODI FÜR DEN RECHTE-BAUM --- */

/* Wenn ein Knoten gesperrt ist (Elternteil ist aus) */
.p-tree-node.is-locked>.p-item {
    background: #f8fafc;
    border-left: 3px solid #cbd5e1;
}

.p-tree-node.is-locked .c-switch {
    opacity: 0.3;
    pointer-events: none;
    /* Schalter unbedienbar machen */
}

/* MODUS: VERSTECKEN (Hide) */
.mode-hide .p-tree-node.is-locked {
    display: none !important;
}

/* MODUS: AUSGRAUEN (Grey) */
.mode-grey .p-tree-node.is-locked>.p-item {
    opacity: 0.4;
    filter: grayscale(1);
    cursor: not-allowed;
}

/* Visual Feedback für Auto-Aktivierung */
.p-item.is-auto-active {
    background-color: rgba(39, 174, 96, 0.05) !important;
    transition: background-color 0.5s;
}

/* Wenn Master-Zugriff aktiv ist, den Baum speziell stylen */
.is-master-active .p-tree-node {
    border-color: rgba(39, 174, 96, 0.2);
}

.is-master-active .p-item {
    background-color: rgba(39, 174, 96, 0.03) !important;
}

.is-auto-selected {
    background-color: rgba(52, 152, 219, 0.2) !important;
}

