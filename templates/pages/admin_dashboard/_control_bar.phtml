<?php if ($auth->hasPermission('dashboard.control_bar.view')) { ?>
    <div class="c-control-bar-wrapper">
        <section class="c-control-bar-section">
            <form method="GET"
                  id="dashboardFilterForm"
                  class="u-flex u-align-center u-gap-s u-flex-wrap u-width-100 u-justify-center"
                  style="margin: 0; background: transparent;">

                <input type="hidden"
                       name="page"
