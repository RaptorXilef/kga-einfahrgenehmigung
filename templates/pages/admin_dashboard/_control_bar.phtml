                    </span>

                    <input type="date"
                           id="filter_start"
                           name="start"
                           value="<?php echo $filterStart; ?>"
                           class="c-control-bar-input">
                    <span class="u-text-muted" style="font-size: 0.75rem; font-weight: 800;">BIS</span>
                    <input type="date"
                           id="filter_end"
                           name="end"
                           value="<?php echo $filterEnd; ?>"
                           class="c-control-bar-input">

                    <span class="u-text-muted u-font-bold" style="font-size: 0.8rem; letter-spacing: 0.05em; margin-left: 10px;">TYP:</span>
                    <select name="type"
                            class="c-control-bar-input"
                            style="width: auto !important; cursor: pointer;"
                            onchange="this.form.submit()">
                        <option value="all"
                                <?php echo $filterType === 'all' ? 'selected' : ''; ?>>
                            Alle Genehmigungen
                        </option>
                        <option value="standard"
                                <?php echo $filterType === 'standard' ? 'selected' : ''; ?>>
                            Nur Standard
