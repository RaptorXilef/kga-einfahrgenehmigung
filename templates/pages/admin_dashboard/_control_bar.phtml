                    <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); font-size: 14px; pointer-events: none; z-index: 10;">
                        <img src="<?php echo $settings['base_url']; ?>assets/img/icons/action-search.webp"
                            class="c-icon"
                             alt="">
                    </span>
                    <input type="text"
                           id="adminSearch"
                           placeholder="Schnellsuche..."
                           title="Suchen Sie nach Namen, KFZ oder SmartCode"
                           class="c-form-input"
                           style="padding-left: 42px; border-radius: 30px; height: 38px; border: 1px solid #e2e8f0; font-size: 0.85rem; width: 100%;">
                </div>
            <?php } ?>
        </section>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const filterStart = document.getElementById('filter_start');
        const filterEnd = document.getElementById('filter_end');

        if (filterStart && filterEnd) {
            // Wenn "Start" (VON) geändert wird
            filterStart.addEventListener('change', () => {
                const startVal = filterStart.value;
                const endVal = filterEnd.value;

                if (startVal && endVal) {
                    // Wenn der neue Start NACH dem aktuellen Ende liegt
                    if (startVal > endVal) {
                        // Ziehe das Ende auf das Startdatum mit
                        filterEnd.value = startVal;
                    }
                }
            });

            // Wenn "Ende" (BIS) geändert wird
            filterEnd.addEventListener('change', () => {
                const startVal = filterStart.value;
                const endVal = filterEnd.value;

                if (startVal && endVal) {
                    // Wenn das neue Ende VOR dem aktuellen Start liegt
                    if (endVal < startVal) {
                        // Ziehe den Start auf das Enddatum zurück
                        filterStart.value = endVal;
                    }
                }
            });
        }
    });

    </script>
<?php } ?>
