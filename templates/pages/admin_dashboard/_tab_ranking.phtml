                                    <strong style="font-size: 1rem;">Nr. <?php echo \htmlspecialchars((string) $pNum); ?></strong>
                                </td>
                                <td>
                                    <?php if ($data['email']) { ?>
                                        <small><a href="mailto:<?php echo $data['email']; ?>" class="u-text-link"><?php echo \htmlspecialchars($data['email']); ?></a></small>
