                        <th style="width: 200px;">Intensität</th>
                    </tr>
                </thead>
                <tbody>
                    <?php if (empty($plots)) { ?>
                        <tr>
                            <td colspan="6" class="u-text-center u-padding-around-l u-text-muted">Keine Daten im Zeitraum gefunden.</td>
                        </tr>
                    <?php } else {
                        $rank = 1;
