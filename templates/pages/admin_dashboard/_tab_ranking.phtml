                                <td>
                                    <div style="background: #f1f5f9; height: 10px; border-radius: 10px; width: 100%; position: relative; overflow: hidden;">
                                        <div style="background: var(--primary-color); width: <?php echo $perc; ?>%; height: 100%; transition: width 0.5s ease-out;"></div>
