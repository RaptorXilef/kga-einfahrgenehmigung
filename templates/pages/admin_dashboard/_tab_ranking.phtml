                                        <small class="u-text-muted"><em>keine Angabe</em></small>
                                    <?php } ?>
                                </td>
                                <td class="u-text-right">
                                    <strong style="color: var(--primary-color);"><?php echo \number_format($data['revenue'], 2, ',', '.'); ?> €</strong>
                                </td>
                                <td class="u-text-center">
                                    <span class="c-badge" style="background: #f1f5f9; min-width: 30px;"><?php echo $data['count']; ?></span>
