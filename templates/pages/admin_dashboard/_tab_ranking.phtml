$plots = $periodStats['plots'] ?? [];
?>
<div class="c-tab-content-container">
    <section class="c-card">
        <header class="c-card__header">
            <h3 class="u-margin-none"><img src="<?php echo $settings['base_url']; ?>assets/img/icons/nav-ranking.webp" class="c-icon" alt=""> Parzellen-Ranking (Top 30)</h3>
            <p class="u-text-muted">Auswertung basierend auf dem gewählten Zeitraum.</p>
        </header>
        <div class="c-card__body u-padding-none" style="overflow-x: auto;">
            <table class="c-table">
                <thead>
                    <tr>
                        <th style="width: 60px; text-align: center;">Rang</th>
                        <th style="width: 120px;">Parzelle</th>
