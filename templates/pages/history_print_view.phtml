        'erstellt'          => $permit->getCreatedAt()->format('d.m.Y H:i'),
        'checkUrl'          => $settings['base_url'] . 'check.php?code=' . $permit->code,
        'config'            => $config,
    ];

// Variablen in den lokalen Scope extrahieren
