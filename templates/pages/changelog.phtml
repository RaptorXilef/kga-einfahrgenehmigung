            <div class="c-card__body u-padding-around-l">
                <!-- Hier landet das fertige HTML -->
                <div id="content-area" class="markdown-body">
                    <div class="u-text-center u-text-muted">
                        Lade Versionshistorie...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Das rohe Markdown wird hier unsichtbar übergeben -->
    <script type="text/markdown" id="raw-markdown" style="display:none;"><?php echo \htmlspecialchars($markdownContent); ?></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const rawMarkdown = document.getElementById('raw-markdown').textContent;
            const contentArea = document.getElementById('content-area');

            if (rawMarkdown.trim() === 'Kein Changelog gefunden.') {
                contentArea.innerHTML = '<div class="u-text-muted u-text-center u-padding-y-l u-font-bold">Keine CHANGELOG.md im System gefunden.</div>';
                return;
            }

            // Markdown in HTML übersetzen
            const html = marked.parse(rawMarkdown);
            // HTML aus Sicherheitsgründen bereinigen und einfügen
            contentArea.innerHTML = DOMPurify.sanitize(html);
        });
    </script>

    <?php include $appRoot . '/templates/components/_footer.phtml'; ?>
