/**
 * Page: Profilbild per Drag n Drop austauschen
 */
?>

<style>
.js-avatar-dropzone {
    position: relative;
    transition: all 0.2s ease;
    border: 2px dashed transparent;
}

.js-avatar-dropzone.js-preview-only {
    border-color: #cbd5e1;
    cursor: pointer;
}

.js-avatar-dropzone.js-preview-only:hover {
    border-color: var(--primary-color);
    background: #f1f5f9;
}

.js-avatar-dropzone.is-dragover {
    background-color: var(--primary-soft) !important;
    border-color: var(--primary-color);
}

.drop-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(52, 152, 219, 0.9);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.9rem;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
    z-index: 10;
}

.js-avatar-dropzone.is-dragover .drop-overlay {
    opacity: 1;
}

</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.js-avatar-dropzone').forEach(zone => {

        // Standard-Browser-Aktionen (wie Bild öffnen) verhindern
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            zone.addEventListener(eventName, e => {
                e.preventDefault();
                e.stopPropagation();
            }, false);
        });

        // Visuelles Feedback beim Drüberziehen
        ['dragenter', 'dragover'].forEach(eventName => {
            zone.addEventListener(eventName, () => zone.classList.add('is-dragover'), false);
        });

        // Visuelles Feedback entfernen, wenn man die Zone verlässt
        ['dragleave', 'drop'].forEach(eventName => {
            zone.addEventListener(eventName, () => zone.classList.remove('is-dragover'), false);
        });

        const inp = zone.querySelector('input[type="file"]'),
            frm = zone.closest('form');

        const handleFile = f => {
            if (!f || !f.type.startsWith('image/')) return alert('Bitte nur Bilder hochladen!');
            if (zone.classList.contains('js-preview-only')) {
                const r = new FileReader();
                r.onload = e => {
                    const img = zone.querySelector('.js-preview-img'),
                        txt = zone.querySelector('.js-preview-text');
                    if (img) {
                        img.src = e.target.result;
                        img.classList.remove('u-hidden');
                    }
                    if (txt) {
                        txt.classList.add('u-hidden');
                    }
                };
                r.readAsDataURL(f);
            } else if (frm) frm.submit();
        };

        // Die Magie beim Loslassen (Drop)
        zone.addEventListener('drop', e => {
            if (e.dataTransfer.files.length > 0) {
                inp.files = e.dataTransfer.files;
                handleFile(inp.files[0]);
            }
        });
        if (inp) inp.addEventListener('change', e => {
            if (e.target.files.length > 0) handleFile(e.target.files[0]);
        });
        if (zone.classList.contains('js-preview-only')) zone.addEventListener('click', () => inp
            .click());
    });
});

</script>
