 * @var \App\Contracts\Storage\GroupRepositoryInterface $groupRepository
 * @var \App\Core\Service\ImageStorageService           $imageStorage
 * @var array                                           $settings
 */
$groupId    = $auth->getGroup();
$groupName  = $groupId;
$groupImage = '';

// (Absicherung falls nicht eingeloggt/übergeben))
if (isset($groupRepository) && $auth->isLoggedIn()) {
    $groups     = $groupRepository->loadAll(); // Wir brauchen die Liste für den Namen
    $groupName  = isset($groups[$groupId]) ? $groups[$groupId]->name : $groupId; // Name finden, sonst ID als Fallback
    $groupImage = isset($imageStorage) ? $imageStorage->getImageUrl('group_images', $groupId, 'icon-group-default.webp') : '';
}

$userImgUrl = isset($imageStorage) ? $imageStorage->getImageUrl('user_images', $auth->getUserId(), 'icon-user-default.webp') : '';
?>
<nav
     style="background: var(--bg-light); border-bottom: 1px solid var(--border-color); padding: 10px 0; margin-bottom: 2rem;">
    <div class="c-tab-content-container"
         style="display: flex; justify-content: space-between; align-items: center;">

        <!-- User Info & Group -->
        <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
            <div class="c-user-pill">
                <span style="font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                    <img src="<?php echo $userImgUrl; ?>"
                         style="width: 28px; height: 24px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border-color);"
                         alt="User Avatar">
                    <a href="profile.php" style="text-decoration: none; color: inherit;"
                       title="Zum Profil">
                        <?php echo \htmlspecialchars($auth->getUsername()); ?>
                    </a>
                </span>

                <div class="c-group-badge">
                    <img src="<?php echo $groupImage; ?>"
                         style="width: 18px; height: 18px; border-radius: 4px; object-fit: cover;"
                         alt="Group Icon">
                    <span><?php echo \htmlspecialchars($groupName); ?></span>
                </div>
            </div>

            <!-- User-Management über Permission absichern -->
            <?php if ($auth->hasPermission('system.permissions.view')) { ?>
                <a href="users.php"
                   class="c-tabs__btn"
                   style="text-decoration: none; padding: 6px 12px; font-size: 0.85rem;">
                <img src="<?php echo $settings['base_url']; ?>assets/img/icons/icon-user.webp" c
