<script>
const kgaConsent = {
    cookieName: 'kga_cookie_consent',
    // Hier wird nun die dynamisch ermittelte $gaId eingetragen
    gaId: '<?php echo \htmlspecialchars($gaId); ?>',

    init: function() {
        if (!this.getCookie()) {
            document.getElementById('kga-consent-banner').style.display = 'block';
        } else {
            this.applyConsent(JSON.parse(this.getCookie()));
        }
    },

    setCookie: function(value) {
        // Gültigkeit: 1 Jahr (365 Tage)
        const d = new window.Date(); // TODO wenn in eigener JS Datei das "window." entfernen
        d.setTime(d.getTime() + (365 * 24 * 60 * 60 * 1000));
        document.cookie = this.cookieName + "=" + JSON.stringify(value) + ";expires=" + d.toUTCString() +
            ";path=/;SameSite=Lax";
        document.getElementById('kga-consent-banner').style.display = 'none';
        this.applyConsent(value);
    },

    getCookie: function() {
        const name = this.cookieName + "=";
        const decodedCookie = decodeURIComponent(document.cookie);
        const ca = decodedCookie.split(';');
        for (let i = 0; i < ca.length; i++) {
            let c = ca[i];
            while (c.charAt(0) == ' ') {
                c = c.substring(1);
            }
            if (c.indexOf(name) == 0) return c.substring(name.length, c.length);
        }
        return "";
    },

    acceptAll: function() {
        this.setCookie({
            essential: true,
            analytics: true
        });
    },

    acceptEssential: function() {
        this.setCookie({
            essential: true,
            analytics: false
        });
    },

    saveSelection: function() {
        const analyticsChecked = document.getElementById('consent-chk-analytics').checked;
        this.setCookie({
            essential: true,
            analytics: analyticsChecked
        });
    },

    toggleDetails: function() {
        const details = document.getElementById('kga-consent-details');
        const btnSave = document.getElementById('btn-save-selection');
        const btnToggle = document.getElementById('btn-toggle-details');

        if (details.style.display === 'none') {
            details.style.display = 'block';
            btnSave.style.display = 'block';
            btnToggle.innerText = '<?php echo \htmlspecialchars($consentConfig['texts']['hide_details']); ?>';
        } else {
            details.style.display = 'none';
            btnSave.style.display = 'none';
            btnToggle.innerText = '<?php echo \htmlspecialchars($consentConfig['texts']['show_details']); ?>';
        }
    },

    applyConsent: function(consentObj) {
        // Wenn Analytics zugestimmt wurde UND eine ID konfiguriert ist, lade das GA-Script
        if (consentObj.analytics && this.gaId && this.gaId !== '') {
            this.loadGoogleAnalytics();
        }
    },

    loadGoogleAnalytics: function() {
        // Verhindert doppeltes Laden
        if (document.getElementById('ga-script')) return;

        const script = document.createElement('script');
        script.id = 'ga-script';
        script.src = 'https://www.googletagmanager.com/gtag/js?id=' + this.gaId;
        script.async = true;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];

        function gtag() {
            dataLayer.push(arguments);
        }
        gtag('js', new window.Date()); // TODO wenn in eigener JS Datei das "window." entfernen

        // IP-Anonymisierung ist in GA4 Standard, aber zur Sicherheit konfigurieren wir es strikt
        gtag('config', this.gaId, {
            'anonymize_ip': true
        });
    }
};

// Start Banner Logic on Load
document.addEventListener('DOMContentLoaded', function() {
    kgaConsent.init();
});

</script>
