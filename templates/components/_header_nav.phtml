/**
 * Component: Admin Header Navigation
 *
 * Path: templates/components/_header_nav.phtml
 *
 * @var \App\Infrastructure\Auth\AuthService $auth
 */
$groupId    = $auth->getGroup();
$groups     = $auth->loadGroups(); // Wir brauchen die Liste für den Namen
$groupName  = $groups[$groupId]['name'] ?? $groupId; // Name finden, sonst ID als Fallback
$groupImage = $auth->getImage('group', $groupId);
?>
<nav style="background: #fff; border-bottom: 1px solid var(--border-color); padding: 0.75rem 0; margin-bottom: 2rem; box-shadow: var(--shadow-sm);">
    <div class="c-tab-content-container" style="display: flex; justify-content: space-between; align-items: center;">

        <!-- User Info & Group -->
        <div style="display: flex; align-items: center; gap: 15px;">
            <div class="c-user-pill">
                <span style="font-weight: 700; font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                    <img src="<?php echo $auth->getImage('user', $_SESSION['user_id'] ?? 'default'); ?>"
                        style="width: 28px; height: 24px; border-radius: 50%; object-fit: cover; border: 1px solid #ddd;">
                    <!-- Klickbarer Name führt zum Profil -->
                    <a href="profile.php" style="text-decoration: none; color: inherit;" title="Zum Profil">
                        <?php echo \htmlspecialchars($auth->getUsername()); ?>
                    </a>
                </span>

                <div class="c-group-badge">
                    <img src="<?php echo $groupImage; ?>" style="width: 18px; height: 18px; border-radius: 4px; object-fit: cover;">
                    <span><?php echo \htmlspecialchars($groupName); ?></span>
                </div>
            </div>

            <!-- User-Management über Permission absichern -->
            <?php if ($auth->hasPermission('system.users.manage')) { ?>
                <a href="users.php" class="c-tabs__btn" style="text-decoration: none; padding: 6px 12px; font-size: 0.85rem;">
                    <img src="<?php echo $settings['base_url']; ?>assets/img/icons/icon-user.webp" class="c-icon" style="width:16px;"> Benutzerverwaltung
                </a>
            <?php } ?>

            <!-- User-Management über Permission absichern -->
            <?php if ($auth->hasPermission('dashboard.view')) { ?>
                <a href="admin.php" class="c-tabs__btn" style="text-decoration: none; padding: 6px 12px; font-size: 0.85rem;">
                    <img src="<?php echo $settings['base_url']; ?>assets/img/icons/nav-stats.webp" class="c-icon" style="width:16px;"> Dashboard
                </a>
            <?php } ?>
        </div>

        <!-- Logout -->
        <a href="admin.php?action=logout" style="text-decoration: none; color: var(--danger-color); font-weight: 700; font-size: 0.85rem;">
