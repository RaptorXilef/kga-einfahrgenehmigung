// Path: templates/components/_footer.phtml

/**
 * Component: Global Dynamic Footer
 *
 * Liest die Version aus der package.json und zeigt Urheberrechts- und GitHub-Informationen.
 *
 * @var string|null $appRoot (optional, wird berechnet falls nicht vorhanden)
 */

// 1. App-Root Fallback (falls die Variable mal nicht übergeben wird)
$root = $appRoot ?? \dirname(__DIR__, 2);

// 2. Versionsnummer aus der package.json auslesen
$version         = 'v0.0.0';
$packageJsonPath = $root . '/package.json';

if (\file_exists($packageJsonPath)) {
    $pkgData = \json_decode((string) \file_get_contents($packageJsonPath), true);
    if (\is_array($pkgData) && isset($pkgData['version'])) {
        $version = 'v' . $pkgData['version'];
    }
}

// 3. Copyright-Jahr Logik (Zeigt "2026" oder "2026 - 2027")
$startYear   = 2026;
$currentYear = (int) \date('Y');
$yearDisplay = $currentYear > $startYear ? "{$startYear} - {$currentYear}" : (string) $startYear;

// 4. Software Details
$developerName = 'Felix Maywald';
$softwareName  = 'KGA-Einfahrgenehmigung / KGA Zufahrts-Manager';
$githubUrl     = 'https://github.com/RaptorXilef/kga-einfahrgenehmigung';
$issuesUrl     = $githubUrl . '/issues';

?>
<footer
        style="padding: 25px 15px; margin-top: auto; border-top: 1px solid var(--border-color); background: transparent; text-align: center;">
    <div
         style="font-size: 0.85rem; color: var(--text-muted); display: flex; flex-direction: column; align-items: center; gap: 8px;">

        <div>
            &copy; <?php echo $yearDisplay; ?> <strong><?php echo \htmlspecialchars($developerName); ?></strong>
        </div>

        <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: center;">
            <a href="<?php echo \htmlspecialchars($githubUrl); ?>"
               target="_blank"
               rel="noopener noreferrer"
               style="color: var(--primary-color); text-decoration: none; font-weight: 600;"
               title="Zum GitHub Repository">
                <?php echo \htmlspecialchars($softwareName); ?>
            </a>

            <span style="background: #e2e8f0; color: #475569; padding: 2px 6px; border-radius: 4px; font-family: monospace; font-size: 0.75rem; letter-spacing: 0.5px;">
                <?php echo \htmlspecialchars($version); ?>
            </span>
        </div>

        <div style="margin-top: 5px;">
            <a href="<?php echo \htmlspecialchars($issuesUrl); ?>"
               target="_blank"
               rel="noopener noreferrer"
               style="color: var(--text-muted); text-decoration: underline; font-size: 0.8rem;">
                Fehler melden / Bug Report
            </a>
        </div>

    </div>
</footer>
