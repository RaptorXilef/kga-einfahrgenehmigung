{
  "name": "@raptorxilef/kga-einfahrgenehmigung",
  "version": "0.1.0",
  "description": "Automatische Verwaltung der KGA-Einfahrgenehmigungen",
  "type": "module",
  "author": "Felix Maywald",
  "license": "CC-BY-NC-SA-4.0",
  "scripts": {
    "// --- PHASE X: Collect ---": "",
    "collect": "pwsh.exe -ExecutionPolicy Bypass -Command \"& (Get-Item scripts/Collect-All*.ps1).FullName\"",
    "collect-info": "powershell -Command \"Get-Location; Get-ChildItem scripts\"",
    "// --- PHASE 0: SETUP & DEV ---": "",
    "setup": "mkdir -p public/assets/css public/assets/js public/assets/img .build/reports",
    "clear": "rimraf public/assets/css/* public/assets/js/*",
    "dev": "npm-run-all2 --parallel dev:*",
    "dev:css": "sass --watch resources/scss/main.scss:public/assets/css/main.css --source-map",
    "dev:js": "chokidar \"resources/js/**/*.js\" -c \"npm run build:js\"",
    "dev:assets": "cpx2 \"resources/assets/**/*\" public/assets/ --watch",
    "// --- PHASE 1: QA & TESTS ---": "",
    "chk": "npm-run-all2 chk:*",
    "chk:sec": "npm audit",
    "chk:sp": "cspell lint \"**/*.{js,scss,php,md}\" --no-progress",
    "chk:md": "markdownlint \"**/*.md\" --ignore node_modules --ignore-path .markdownlintignore",
    "chk:size": "source-map-explorer public/assets/css/main.min.css public/assets/js/main.min.js",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui --passWithNoTests",
    "// --- PHASE 3: LINT & FORMAT (AUTO-FIX) ---": "",
    "fmt": "npm-run-all2 fmt:*",
    "fmt:js": "prettier \"resources/js/**/*.js\" --write && eslint resources/js --fix",
    "fmt:css": "prettier \"resources/scss/**/*.scss\" --write && stylelint \"resources/scss/**/*.scss\" --fix",
    "fmt:html": "prettier \"**/*.html\" --write",
    "// --- PHASE 4: ANALYZE (READ-ONLY) ---": "",
    "analyze": "npm-run-all2 analyze:*",
    "analyze:js": "eslint resources/js",
    "analyze:css": "stylelint \"resources/scss/**/*.scss\"",
    "analyze:html": "html_codesniffer https://kga-einfahrgenehmigung",
    "// --- PHASE 5: UX & PERFORMANCE ---": "",
    "audit": "npm-run-all2 audit:*",
    "audit:a11y": "pa11y-ci --threshold 2 --ignore-ssl-errors",
    "audit:ux": "lhci autorun",
    "audit:ux:view": "serve .build/reports/lighthouse",
    "// --- PHASE 6: BUILD & RELEASE ---": "",
    "make": "npm-run-all2 clear build:* opt:*",
    "// KETTE: SASS -> PURGE -> POSTCSS (Minify)": "",
    "build:css": "sass resources/scss/main.scss public/assets/css/main.css --no-source-map && purgecss --config purgecss.config.js && postcss public/assets/css/main.min.css -o public/assets/css/main.min.css",
    "build:js": "terser resources/js/main.js -o public/assets/js/main.min.js --compress --mangle --module",
    "opt:svg": "svgo -f resources/assets/img -o public/assets/img",
    "opt:crit": "critical https://kga-einfahrgenehmigung --width 1300 --height 900 --target public/assets/css/critical.css --minify",
    "// --- RELEASE-MANAGEMENT ---": "",
    "rel": "release-it",
    "rel:alpha": "release-it --preRelease=alpha",
    "rel:beta": "release-it --preRelease=beta",
    "rel:rc": "release-it --preRelease=rc",
    "rel:patch": "release-it --increment=patch --ci",
    "ci:rel:test": "release-it --dry-run --ci",
    "rel:init": "release-it --first-release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@cspell/dict-de-de": "^4.1.2",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@prettier/plugin-php": "^0.24.0",
    "@release-it/conventional-changelog": "^8.0.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "chokidar-cli": "^3.0.0",
    "conventional-commits-filter": "^5.0.0",
    "conventional-commits-parser": "^6.3.0",
    "cpx2": "^8.0.0",
    "critical": "^7.2.1",
    "cspell": "^9.7.0",
    "cssnano": "^7.1.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "html_codesniffer": "^2.5.1",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.48.0",
    "npm-check-updates": "^19.6.3",
    "npm-run-all2": "^8.0.4",
    "pa11y": "^9.1.1",
    "pa11y-ci": "^4.1.0",
    "pa11y-ci-reporter-html": "^8.0.1",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "prettier": "3.8.1",
    "purgecss": "^8.0.0",
    "release-it": "^17.10.0",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "source-map-explorer": "^2.5.3",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-order": "^7.0.0",
    "svgo": "^4.0.1",
    "terser": "^5.46.0",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "glob": "^9.0.0",
    "inflight": "lru-cache",
    "tmp": "^0.2.3",
    "undici": "^6.23.0",
    "minimatch": "^9.0.0",
    "lodash": "^4.17.21"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ]
}
